@using Microsoft.EntityFrameworkCore
@using Transport.Domain.Entities
@using Transport.Infrastructure.Data

@inject TransportDbContext Db
@inject MasterDbContext    MasterDb
@inject ITenantService     TenantService
@inject IDialogService     Dialog
@inject ISnackbar          Snackbar

<MudDialog Style="min-width:600px;">
    <TitleContent>
        <div style="display:flex; align-items:center; gap:10px;">
            <MudText Typo="Typo.h6">Zaposleni</MudText>
            @if (VozacId > 0 && _entitet is not null)
            {
                @if (_entitet.aktivan == 1)
                {
                    <MudChip T="string" Color="Color.Success" Size="Size.Small" Style="margin:0;">Aktivan</MudChip>
                }
                else
                {
                    <MudChip T="string" Color="Color.Default" Size="Size.Small" Style="margin:0;">Neaktivan</MudChip>
                }
            }
        </div>
    </TitleContent>
    <DialogContent>
        <MudTabs Elevation="0" Rounded="false" ApplyEffectsToContainer="true">

            @* ── TAB 1 — Osnovni podaci ─────────────────────────────── *@
            <MudTabPanel Text="Osnovni podaci" Icon="@Icons.Material.Filled.Person">
                <MudGrid Spacing="2" Class="mt-2">

                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_ime"
                                      Label="Ime *"
                                      Variant="Variant.Outlined"
                                      ShrinkLabel="true"
                                      Required="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_prezime"
                                      Label="Prezime *"
                                      Variant="Variant.Outlined"
                                      ShrinkLabel="true"
                                      Required="true" />
                    </MudItem>

                    <MudItem xs="12" sm="8">
                        <MudTextField @bind-Value="_adresa"
                                      Label="Adresa"
                                      Variant="Variant.Outlined"
                                      ShrinkLabel="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudTextField @bind-Value="_mesto"
                                      Label="Mesto"
                                      Variant="Variant.Outlined"
                                      ShrinkLabel="true" />
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_telefon"
                                      Label="Telefon"
                                      Variant="Variant.Outlined"
                                      ShrinkLabel="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_telefonMob"
                                      Label="Mobilni"
                                      Variant="Variant.Outlined"
                                      ShrinkLabel="true" />
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_mail"
                                      Label="E-mail"
                                      Variant="Variant.Outlined"
                                      ShrinkLabel="true"
                                      InputType="InputType.Email" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_zaposlenje"
                                      Label="Zaposlenje"
                                      Variant="Variant.Outlined"
                                      ShrinkLabel="true" />
                    </MudItem>

                    <MudItem xs="12" sm="4">
                        <MudTextField @bind-Value="_jmbg"
                                      Label="JMBG"
                                      Variant="Variant.Outlined"
                                      ShrinkLabel="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudTextField @bind-Value="_brojLK"
                                      Label="Broj LK"
                                      Variant="Variant.Outlined"
                                      ShrinkLabel="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudTextField @bind-Value="_pasos"
                                      Label="Br. Pasoša"
                                      Variant="Variant.Outlined"
                                      ShrinkLabel="true" />
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <DateInput Label="Istek dozvole" @bind-Value="_istekDozvole" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <DateInput Label="Istek pasoša" @bind-Value="_istekPasosa" />
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <DateInput Label="Zaposlen od" @bind-Value="_datumZaposlenja" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <DateInput Label="Datum rođenja" @bind-Value="_datumRodjenja" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudTextField @bind-Value="_komentar"
                                      Label="Komentar"
                                      Variant="Variant.Outlined"
                                      ShrinkLabel="true"
                                      Lines="2" />
                    </MudItem>

                </MudGrid>
            </MudTabPanel>

            @* ── TAB 2 — Obračun plate ──────────────────────────────── *@
            <MudTabPanel Text="Obračun plate" Icon="@Icons.Material.Filled.Payments">
                <MudGrid Spacing="3" Class="mt-2">

                    @* Radio izbor tipa — ne koristi popup, radi pouzdano unutar dialoga *@
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Class="mb-1 mud-text-secondary">
                            Tip isplate
                        </MudText>
                        <MudRadioGroup T="string" @bind-Value="_tipIsplate">
                            <MudRadio T="string" Value="@("DNEVNICA")" Color="Color.Primary">Dnevnica</MudRadio>
                            <MudRadio T="string" Value="@("PROCENAT")" Color="Color.Primary">Procenat</MudRadio>
                            <MudRadio T="string" Value="@("FIXNO")"    Color="Color.Primary">Fiksna plata</MudRadio>
                            <MudRadio T="string" Value="@("PO_KM")"    Color="Color.Primary">Po kilometru</MudRadio>
                        </MudRadioGroup>
                    </MudItem>

                    @* Dinamičko polje ovisno o izabranom tipu *@
                    @if (_tipIsplate == "DNEVNICA")
                    {
                        <MudItem xs="12" sm="5">
                            <MudNumericField @bind-Value="_dnevnica"
                                             Label="Dnevnica"
                                             Variant="Variant.Outlined"
                                             Format="F2"
                                             Adornment="Adornment.End"
                                             AdornmentText="RSD" />
                        </MudItem>
                    }
                    else if (_tipIsplate == "PROCENAT")
                    {
                        <MudItem xs="12" sm="5">
                            <MudNumericField @bind-Value="_procenat"
                                             Label="Procenat za platu"
                                             Variant="Variant.Outlined"
                                             Format="F2"
                                             Adornment="Adornment.End"
                                             AdornmentText="%" />
                        </MudItem>
                    }
                    else if (_tipIsplate == "FIXNO")
                    {
                        <MudItem xs="12" sm="5">
                            <MudNumericField @bind-Value="_fixnoPlata"
                                             Label="Fiksna plata"
                                             Variant="Variant.Outlined"
                                             Format="F2"
                                             Adornment="Adornment.End"
                                             AdornmentText="RSD" />
                        </MudItem>
                    }
                    else if (_tipIsplate == "PO_KM")
                    {
                        <MudItem xs="12" sm="5">
                            <MudNumericField @bind-Value="_cenaPoKm"
                                             Label="Cena po kilometru"
                                             Variant="Variant.Outlined"
                                             Format="F2"
                                             Adornment="Adornment.End"
                                             AdornmentText="RSD/km" />
                        </MudItem>
                    }

                </MudGrid>
            </MudTabPanel>

            @* ── TAB 3 — Bankovni podaci ─────────────────────────────── *@
            <MudTabPanel Text="Bankovni podaci" Icon="@Icons.Material.Filled.AccountBalance">
                <MudGrid Spacing="3" Class="mt-2">
                    <MudItem xs="12">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="() => OtvoriDodajRacun()">
                            DODAJ RAČUN
                        </MudButton>
                    </MudItem>

                    <MudItem xs="12">
                        @if (_racuni.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                Nema bankovnih računa.
                            </MudText>
                        }
                        else
                        {
                            <MudDataGrid T="VozacRacun"
                                         @key="_racuni"
                                         Items="_racuni"
                                         Dense="true"
                                         Striped="true"
                                         Hover="true"
                                         Bordered="true">
                                <Columns>
                                    <PropertyColumn Property="x => x.nazivBanke" Title="Naziv banke" />
                                    <PropertyColumn Property="x => x.racun" Title="Broj računa" />
                                    <PropertyColumn Property="x => x.IBAN" Title="IBAN" />
                                    <PropertyColumn Property="x => x.valuta" Title="Valuta" />
                                    <PropertyColumn Property="x => x.tipRacuna" Title="Tip" />
                                    <TemplateColumn Title="Glavni" Width="110px">
                                        <CellTemplate>
                                            @if (context.Item.glavniRacun == 1)
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" />
                                            }
                                        </CellTemplate>
                                    </TemplateColumn>
                                    <TemplateColumn Title="" Width="70px">
                                        <CellTemplate>
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Color="Color.Error"
                                                           Size="Size.Small"
                                                           OnClick="@(() => UkloniRacun(context.Item))" />
                                        </CellTemplate>
                                    </TemplateColumn>
                                </Columns>
                            </MudDataGrid>
                        }
                    </MudItem>
                </MudGrid>
            </MudTabPanel>

        </MudTabs>
    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Save"
                   OnClick="@(async () => await Sacuvaj())">
            Sačuvaj
        </MudButton>

        @if (VozacId > 0)
        {
            @if (_webKorisnik is null)
            {
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.PersonAdd"
                           OnClick="OtvoriRegistraciju">
                    Registruj kao korisnika
                </MudButton>
            }
            else
            {
                <MudButton Variant="Variant.Filled"
                           Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.ManageAccounts"
                           OnClick="OtvoriUpravljanje">
                    Upravljaj pristupom
                </MudButton>
            }

            @if (_entitet?.aktivan == 1)
            {
                <MudButton Variant="Variant.Filled"
                           Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.PersonOff"
                           OnClick="Deaktiviraj">
                    Deaktiviraj
                </MudButton>
            }
            else
            {
                <MudButton Variant="Variant.Filled"
                           Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.PersonAdd"
                           OnClick="Aktiviraj">
                    Aktiviraj
                </MudButton>
            }
        }

        <MudButton Variant="Variant.Outlined"
                   OnClick="() => MudDialog.Cancel()">
            Odustani
        </MudButton>
    </DialogActions>
</MudDialog>

@implements IDisposable

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter]          public int        VozacId  { get; set; }

    private Vozac?      _entitet;
    private WebKorisnik? _webKorisnik;
    private bool         _disposed;

    // Tab 1
    private string    _ime          = string.Empty;
    private string    _prezime      = string.Empty;
    private string?   _adresa;
    private string?   _mesto;
    private string?   _telefon;
    private string?   _telefonMob;
    private string?   _mail;
    private string?   _zaposlenje;
    private string?   _jmbg;
    private string?   _brojLK;
    private string?   _pasos;
    private string?   _komentar;
    private string _istekDozvole    = string.Empty;
    private string _istekPasosa     = string.Empty;
    private string _datumZaposlenja = string.Empty;
    private string _datumRodjenja   = string.Empty;

    // Tab 2
    private string   _tipIsplate  = "DNEVNICA";
    private decimal? _dnevnica;
    private decimal? _procenat;
    private decimal? _fixnoPlata;
    private decimal? _cenaPoKm;

    private List<VozacRacun> _racuni = [];

    protected override async Task OnInitializedAsync()
    {
        if (VozacId > 0)
        {
            _entitet = await Db.Vozaci.IgnoreQueryFilters()
                                      .FirstOrDefaultAsync(v => v.Broj == VozacId);
            if (_entitet is not null)
            {
                _ime             = _entitet.Ime         ?? string.Empty;
                _prezime         = _entitet.Prezime     ?? string.Empty;
                _adresa          = _entitet.Adresa;
                _mesto           = _entitet.Mesto;
                _telefon         = _entitet.Telefon;
                _telefonMob      = _entitet.TelefonMob;
                _mail            = _entitet.Mail;
                _zaposlenje      = _entitet.Zaposlenje;
                _jmbg            = _entitet.JMBG;
                _brojLK          = _entitet.BrojLK;
                _pasos           = _entitet.pasos;
                _komentar        = _entitet.Komentar;
                _tipIsplate      = _entitet.tipIsplate  ?? "DNEVNICA";
                _dnevnica        = _entitet.dnevnica;
                _procenat        = _entitet.procenatZaPlatu;
                _fixnoPlata      = _entitet.fixnoPlata;
                _cenaPoKm        = _entitet.cenaPoKm;

                _istekDozvole    = ToIso(_entitet.istekDozvole);
                _istekPasosa     = ToIso(_entitet.istekPasosa);
                _datumZaposlenja = ToIso(_entitet.datumZaposlenja);
                _datumRodjenja   = ToIso(_entitet.datumRodjenja);

                await UcitajRacune();
            }
        }

        if (VozacId > 0)
            await UcitajWebKorisnika();
    }

    private async Task UcitajWebKorisnika()
    {
        var idLicence = TenantService.GetIdLicence();
        _webKorisnik = await MasterDb.WebKorisnici
            .FirstOrDefaultAsync(k => k.IdZaposlenog == VozacId && k.IdLicence == idLicence);
    }

    private async Task OtvoriRegistraciju()
    {
        if (_disposed) return;

        if (_entitet is null || _entitet.Broj == 0)
        {
            var sacuvano = await Sacuvaj(false);
            if (!sacuvano || _disposed) return;
        }

        if (_entitet is null) return;

        var imeZaposlenog = $"{_ime} {_prezime}".Trim();
        var opts = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var prms = new DialogParameters<WebKorisnikRegistracijaDialog>
        {
            { x => x.VozacId,       _entitet.Broj },
            { x => x.ImeZaposlenog, imeZaposlenog }
        };
        var dialog = await Dialog.ShowAsync<WebKorisnikRegistracijaDialog>("Registruj kao korisnika", prms, opts);

        if (!(await dialog.Result).Canceled && !_disposed)
        {
            await UcitajWebKorisnika();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OtvoriUpravljanje()
    {
        if (_disposed || _webKorisnik is null) return;

        var opts = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var prms = new DialogParameters<WebKorisnikUpravljanjeDialog>
        {
            { x => x.KorisnikId, _webKorisnik.IdKorisnika }
        };
        var dialog = await Dialog.ShowAsync<WebKorisnikUpravljanjeDialog>("Upravljaj pristupom", prms, opts);

        if (!(await dialog.Result).Canceled && !_disposed)
        {
            await UcitajWebKorisnika();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<bool> Sacuvaj(bool closeDialog = true)
    {
        if (string.IsNullOrWhiteSpace(_ime))
        {
            Snackbar.Add("Ime je obavezno polje.", Severity.Warning);
            return false;
        }

        if (_entitet is null)
        {
            _entitet = new Vozac { aktivan = 1 };
            Db.Vozaci.Add(_entitet);
        }

        _entitet.Ime             = _ime;
        _entitet.Prezime         = _prezime;
        _entitet.Adresa          = _adresa;
        _entitet.Mesto           = _mesto;
        _entitet.Telefon         = _telefon;
        _entitet.TelefonMob      = _telefonMob;
        _entitet.Mail            = _mail;
        _entitet.Zaposlenje      = _zaposlenje;
        _entitet.JMBG            = _jmbg;
        _entitet.BrojLK          = _brojLK;
        _entitet.pasos           = _pasos;
        _entitet.Komentar        = _komentar;
        _entitet.tipIsplate      = _tipIsplate;
        _entitet.dnevnica        = _tipIsplate == "DNEVNICA" ? _dnevnica       : null;
        _entitet.procenatZaPlatu = _tipIsplate == "PROCENAT" ? _procenat       : null;
        _entitet.fixnoPlata      = _tipIsplate == "FIXNO"    ? _fixnoPlata     : null;
        _entitet.cenaPoKm        = _tipIsplate == "PO_KM"    ? _cenaPoKm       : null;
        _entitet.istekDozvole    = FromIso(_istekDozvole);
        _entitet.istekPasosa     = FromIso(_istekPasosa);
        _entitet.datumZaposlenja = FromIso(_datumZaposlenja);
        _entitet.datumRodjenja   = FromIso(_datumRodjenja);

        await Db.SaveChangesAsync();
        if (_disposed) return false;

        Snackbar.Add("Zaposleni sačuvan.", Severity.Success);

        if (closeDialog && !_disposed)
        {
            MudDialog.Close(DialogResult.Ok(true));
        }

        return true;
    }

    private void OtvoriDodajRacun()
    {
        if (_disposed) return;
        _ = OtvoriDodajRacunAsync();
    }

    private async Task OtvoriDodajRacunAsync()
    {
        if (_disposed) return;

        if (_entitet is null || _entitet.Broj == 0)
        {
            var sacuvano = await Sacuvaj(false);
            if (!sacuvano || _disposed) return;
        }

        if (_entitet is null) return;

        var opts = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var parameters = new DialogParameters<RacunVozacaDialog> { { x => x.VozacId, _entitet.Broj } };
        var dialog = await Dialog.ShowAsync<RacunVozacaDialog>("Novi račun", parameters, opts);

        try
        {
            var result = await dialog.Result;
            if (_disposed) return;
            if (!result.Canceled)
            {
                await UcitajRacune();
                if (!_disposed)
                {
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (ObjectDisposedException)
        {
            if (!_disposed)
            {
                Snackbar.Add("Dialog je zatvoren pre nego što je rezultat mogao da se obradi.", Severity.Error);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            if (!_disposed)
            {
                Snackbar.Add($"Greška pri otvaranju računa: {ex.Message}", Severity.Error);
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task UcitajRacune()
    {
        if (_disposed) return;

        if (_entitet is null || _entitet.Broj == 0)
        {
            _racuni.Clear();
            return;
        }

        _racuni = await Db.VozacRacuni
            .Where(r => r.idVozaca == _entitet.Broj)
            .OrderByDescending(r => r.glavniRacun)
            .ThenBy(r => r.nazivBanke)
            .ToListAsync();
    }

    private async Task UkloniRacun(VozacRacun racun)
    {
        if (_disposed || racun is null) return;

        racun.aktivan = 0;
        await Db.SaveChangesAsync();
        if (_disposed) return;

        Snackbar.Add("Račun je uklonjen.", Severity.Info);
        await UcitajRacune();
    }

    private async Task Deaktiviraj()
    {
        if (_disposed || _entitet is null) return;

        var poruka = _webKorisnik?.Aktivan == 1
            ? "Da li ste sigurni? Zaposleni neće biti obrisan, samo deaktiviran. Njegov web pristup će takođe biti deaktiviran."
            : "Da li ste sigurni? Zaposleni neće biti obrisan, samo deaktiviran.";

        var potvrda = await Dialog.ShowMessageBox(
            "Potvrda deaktivacije",
            poruka,
            yesText: "Da, deaktiviraj",
            cancelText: "Odustani");

        if (_disposed || potvrda != true) return;

        _entitet.aktivan = 0;
        await Db.SaveChangesAsync();
        if (_disposed) return;

        // Kaskadna deaktivacija: deaktiviran zaposleni ne može da se loguje
        if (_webKorisnik is not null && _webKorisnik.Aktivan == 1)
        {
            _webKorisnik.Aktivan = 0;
            await MasterDb.SaveChangesAsync();
        }

        Snackbar.Add("Zaposleni deaktiviran.", Severity.Info);
        MudDialog.Close(DialogResult.Ok(true));
    }

    private async Task Aktiviraj()
    {
        if (_disposed || _entitet is null) return;

        var potvrda = await Dialog.ShowMessageBox(
            "Potvrda aktivacije",
            "Da li ste sigurni da želite da aktivirate ovog zaposlenog?",
            yesText: "Da, aktiviraj",
            cancelText: "Odustani");

        if (_disposed || potvrda != true) return;

        _entitet.aktivan = 1;
        await Db.SaveChangesAsync();
        if (_disposed) return;

        Snackbar.Add("Zaposleni aktiviran.", Severity.Success);
        MudDialog.Close(DialogResult.Ok(true));
    }

    private static string ToIso(DateOnly? d)
        => d.HasValue ? d.Value.ToString("yyyy-MM-dd") : string.Empty;

    private static DateOnly? FromIso(string s)
        => DateTime.TryParse(s, out var dt) ? DateOnly.FromDateTime(dt) : null;

    public void Dispose()
    {
        _disposed = true;
    }
}
