@inject ITenantService TenantService

<MudNavMenu>

    @* ── OPERATIVA ────────────────────────────────────── *@
    <div class="nav-section-title">Operativa</div>
    <MudNavLink Href="/" Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Home">
        Početna
    </MudNavLink>
    <MudNavLink Href="/partneri"
                Icon="@Icons.Material.Filled.Business">
        Partneri
    </MudNavLink>
    <MudNavLink Href="/vozaci"
                Icon="@Icons.Material.Filled.People">
        Vozači / Zaposleni
    </MudNavLink>
    <MudNavLink Href="/vozila"
                Icon="@Icons.Material.Filled.DirectionsCar">
        Vozila
    </MudNavLink>
    <MudNavLink Href="/vozila/vazni-datumi"
                Icon="@Icons.Material.Filled.EventBusy">
        Važni datumi
    </MudNavLink>

    @* ── DOKUMENTA ────────────────────────────────────── *@
    <div class="nav-section-title">Dokumenta</div>
    <MudNavLink Href="/fakturisanje/racuni"
                Icon="@Icons.Material.Filled.Receipt">
        Fakturisanje
    </MudNavLink>
    <MudNavLink Href="/fakturisanje/gotovinski"
                Icon="@Icons.Material.Filled.CurrencyExchange">
        Gotovski računi
    </MudNavLink>
    <MudNavLink Href="/fakturisanje/otpremnice"
                Icon="@Icons.Material.Filled.LocalShipping">
        Otpremnice
    </MudNavLink>
    <MudNavLink Href="/fakturisanje/ponude"
                Icon="@Icons.Material.Filled.Assignment">
        Ponude
    </MudNavLink>
    <MudNavLink Href="/dozvole"
                Icon="@Icons.Material.Filled.CardMembership">
        Dozvole MUP
    </MudNavLink>
    @if (TenantService.GetTransportModulAktivan())
    {
        <MudNavLink Href="/transport/nalozi"
                    Icon="@Icons.Material.Filled.DriveEta">
            Transport / Ture
        </MudNavLink>
        <MudNavLink Href="/nalozi"
                    Icon="@Icons.Material.Filled.ReceiptLong">
            Nalozi za prevoz
        </MudNavLink>
        <MudNavLink Href="/transport/putni-nalozi"
                    Icon="@Icons.Material.Filled.Route">
            Putni nalozi
        </MudNavLink>
        <MudNavLink Href="/statistika/ture"
                    Icon="@Icons.Material.Filled.BarChart">
            Statistika tura
        </MudNavLink>
        <MudNavLink Href="/statistika/nalozi"
                    Icon="@Icons.Material.Filled.Analytics">
            Statistika naloga
        </MudNavLink>
    }

    @* ── FINANSIJE ────────────────────────────────────── *@
    <div class="nav-section-title">Finansije</div>
    <MudNavLink Href="/troskovi"
                Icon="@Icons.Material.Filled.AccountBalance">
        Troškovi
    </MudNavLink>
    <MudNavLink Href="/finansije/kartice"
                Icon="@Icons.Material.Filled.CreditCard">
        Finansije
    </MudNavLink>
    <MudNavLink Href="/finansije/dugovanja"
                Icon="@Icons.Material.Filled.MoneyOff">
        Dugovanja
    </MudNavLink>
    <MudNavLink Href="/finansije/uplate"
                Icon="@Icons.Material.Filled.Payment">
        Uplate
    </MudNavLink>
    <MudNavLink Href="/osoblje/plate"
                Icon="@Icons.Material.Filled.Wallet">
        Plate
    </MudNavLink>
    <MudNavLink Href="/osoblje/dnevnice"
                Icon="@Icons.Material.Filled.Money">
        Dnevnice
    </MudNavLink>

    @* ── RESURSI ──────────────────────────────────────── *@
    <div class="nav-section-title">Resursi</div>
    <MudNavLink Href="/magacin/lager"
                Icon="@Icons.Material.Filled.Inventory">
        Magacin
    </MudNavLink>
    <MudNavLink Href="/planiranje/planer"
                Icon="@Icons.Material.Filled.CalendarToday">
        Planiranje
    </MudNavLink>
    <MudNavLink Href="/podsetnici"
                Icon="@Icons.Material.Filled.NotificationsActive">
        Podsetnici
    </MudNavLink>

    @* ── FINANSIJSKI ALATI ────────────────────────────── *@
    <div class="nav-section-title">Finansijski alati</div>
    <MudNavLink Href="/kursna-lista"
                Icon="@Icons.Material.Filled.CurrencyExchange">
        Kursna lista
    </MudNavLink>

    @* ── PODEŠAVANJA ──────────────────────────────────── *@
    <MudNavGroup Title="Podešavanja"
                 Icon="@Icons.Material.Filled.Settings"
                 Expanded="false">
        <MudNavLink Href="/podesavanja"
                    Icon="@Icons.Material.Filled.Tune">
            Opšta podešavanja
        </MudNavLink>
        <MudNavLink Href="/podesavanja/podaci-firme"
                    Icon="@Icons.Material.Filled.Business">
            Podaci firme
        </MudNavLink>
        <MudNavLink Href="/podesavanja/sifarnici"
                    Icon="@Icons.Material.Filled.ListAlt">
            Šifarnici
        </MudNavLink>
        <MudNavLink Href="/administracija/podesavanja"
                    Icon="@Icons.Material.Filled.AdminPanelSettings">
            Administracija
        </MudNavLink>
    </MudNavGroup>

</MudNavMenu>
