    private void ToggleCekiran(int id, bool value)
    {
        if (value) _cekirani.Add(id);
        else       _cekirani.Remove(id);
        StateHasChanged();
    }

    private async Task StampajCekirane()
    {
        if (_cekirani.Count == 0) return;
        var ids = string.Join(",", _cekirani);
        await JS.InvokeVoidAsync("open", $"/transport/nalozi-stampa?ids={ids}", "_blank");
    }

