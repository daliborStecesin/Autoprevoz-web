    private string NalogRowStyle(NalogPrevoz item, int _) => item.Status switch
    {
        "U TOKU"  => "background-color:#EBF5FB !important;",
        "ZAVRSEN" => "background-color:#EAFAF1 !important;",
        "OTKAZAN" => "background-color:#FDEDEC !important;",
        _         => string.Empty
    };

    private static Color StatusBoja(string? status) => status switch
    {
        "U TOKU"  => Color.Warning,
        "ZAVRSEN" => Color.Success,
        "OTKAZAN" => Color.Error,
        _         => Color.Default
    };

    private static string StatusLabel(string? status) => status switch
    {
        "ZAVRSEN" => "ZAVRŠEN",
        "OTKAZAN" => "OTKAZAN",
        _         => status ?? "—"
    };

    private static string ValutaOznaka(string? valuta) =>
        valuta?.Contains("EUR") == true ? "EUR" : "RSD";

    private async Task ExportExcel()
    {
        using var wb = new XLWorkbook();
        var ws = wb.Worksheets.Add("Nalozi");

        var headers = new[]
        {
            "Br. naloga", "Br. ture", "Tip", "Nalogodavac", "Prevoznik",
            "Mesto utovara", "Mesto istovara", "Datum utovara", "Datum istovara",
            "Cena (EUR)", "Plaćeno (EUR)", "Razlika (EUR)", "Status"
        };

        for (int i = 0; i < headers.Length; i++)
        {
            var h = ws.Cell(1, i + 1);
            h.Value = headers[i];
            h.Style.Font.Bold = true;
            h.Style.Font.FontColor = XLColor.White;
            h.Style.Fill.BackgroundColor = XLColor.FromHtml("#2D3E50");
        }

        int row = 2;
        foreach (var n in _nalozi)
        {
            var razlika = (double)((n.CenaTransporta ?? 0m) - (n.PlacenTransport ?? 0m));
            ws.Cell(row, 1).Value  = n.BrNaloga;
            ws.Cell(row, 2).Value  = n.BrTure;
            ws.Cell(row, 3).Value  = n.TipNaloga;
            ws.Cell(row, 4).Value  = n.Uvoznik;
            ws.Cell(row, 5).Value  = n.Napomena2;
            ws.Cell(row, 6).Value  = n.MestoUtovara;
            ws.Cell(row, 7).Value  = n.MestoIstovara;
            ws.Cell(row, 8).Value  = n.DatumUtovara?.ToString("dd.MM.yyyy");
            ws.Cell(row, 9).Value  = n.DatumIstovara?.ToString("dd.MM.yyyy");
            ws.Cell(row, 10).Value = (double)(n.CenaTransporta  ?? 0m);
            ws.Cell(row, 11).Value = (double)(n.PlacenTransport ?? 0m);
            ws.Cell(row, 12).Value = razlika;
            ws.Cell(row, 13).Value = StatusLabel(n.Status);

            if (razlika > 0)
                ws.Row(row).Style.Font.FontColor = XLColor.Red;

            row++;
        }

        ws.Columns().AdjustToContents();

        using var ms = new MemoryStream();
        wb.SaveAs(ms);
        var base64 = Convert.ToBase64String(ms.ToArray());
        await JS.InvokeVoidAsync("downloadFile", $"nalozi_{DateTime.Today:yyyy-MM-dd}.xlsx", base64);
    }

    private static DateTime? ParseDate(string? s) =>
        DateTime.TryParse(s, out var d) ? d.Date : null;
