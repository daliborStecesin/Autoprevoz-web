    // ── Autocomplete helpers ──

    private List<Partner> FiltrirajPartnere(string pretraga) =>
        string.IsNullOrWhiteSpace(pretraga)
            ? [.. _sviPartneri.Take(10)]
            : [.. _sviPartneri
                .Where(p => (p.Naziv ?? "").Contains(pretraga, StringComparison.OrdinalIgnoreCase) ||
                            (p.Mesto  ?? "").Contains(pretraga, StringComparison.OrdinalIgnoreCase))
                .Take(8)];

    private List<Vozac> FiltrirajVozace(string pretraga) =>
        string.IsNullOrWhiteSpace(pretraga)
            ? [.. _sviVozaci.Take(12)]
            : [.. _sviVozaci
                .Where(v => ((v.Ime ?? "") + " " + (v.Prezime ?? "")).Contains(pretraga, StringComparison.OrdinalIgnoreCase) ||
                            ((v.Prezime ?? "") + " " + (v.Ime ?? "")).Contains(pretraga, StringComparison.OrdinalIgnoreCase))
                .Take(8)];

    private List<Vozilo> FiltrirajVozila(string pretraga) =>
        string.IsNullOrWhiteSpace(pretraga)
            ? [.. _sviVozila.Take(12)]
            : [.. _sviVozila
                .Where(v => (v.registarskaOznaka ?? "").Contains(pretraga, StringComparison.OrdinalIgnoreCase) ||
                            (v.marka            ?? "").Contains(pretraga, StringComparison.OrdinalIgnoreCase))
                .Take(8)];

