@page "/transport/nalog-transport/{IdNaloga:int}"
@layout EmptyLayout
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using Transport.Domain.Entities
@using Transport.Infrastructure.Data

@inject ITenantService     TenantService
@inject TransportDbContext Db
@inject NavigationManager  Nav
@inject IJSRuntime         JS

<PageTitle>@(_nalog is not null ? $"Nalog {_nalog.BrNaloga}" : "Nalog za transport")</PageTitle>

<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Arial, Helvetica, sans-serif; font-size: 10pt; color: #000; background: #fff; }
    .wrap { padding: 20px 32px; }

    /* ── Strana 1 ── */
    .header-row { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px; }
    .firm-block { font-size: 9pt; line-height: 1.6; }
    .firm-block .naziv { font-size: 12pt; font-weight: bold; }

    .doc-naslov { font-size: 14pt; font-weight: bold; text-align: center;
                  border-top: 2px solid #000; border-bottom: 2px solid #000;
                  padding: 8px 0; margin: 12px 0; letter-spacing: 1px; }
    .doc-br { text-align: center; font-size: 10pt; margin-bottom: 16px; color: #333; }
    .doc-br strong { font-size: 13pt; color: #1a237e; }

    .blok { border: 1px solid #333; padding: 10px 14px; margin-bottom: 10px; }
    .blok .naslov { font-size: 8pt; color: #555; text-transform: uppercase;
                    font-weight: bold; margin-bottom: 5px; letter-spacing: 0.5px; }
    .blok .vrednost { font-size: 10.5pt; font-weight: bold; color: #000; line-height: 1.5; }
    .blok .sub { font-size: 8.5pt; color: #444; margin-top: 3px; }

    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px; }
    .three-col { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin-bottom: 10px; }

    .info-row { font-size: 9pt; margin-bottom: 5px; }
    .info-row .lbl { color: #555; min-width: 130px; display: inline-block; }
    .info-row .val { font-weight: bold; }

    .napomena-box { border: 1px dashed #666; padding: 8px 12px; margin-top: 10px;
                    font-size: 9pt; min-height: 40px; background: #fafafa; }

    /* ── Strana 2 — Cena + Uslovi ── */
    .page-break { page-break-before: always; padding-top: 6px; }
    .page-break .print-header { margin-bottom: 8px; }

    .cena-traka { display: flex; justify-content: space-between; align-items: baseline;
                  border-top: 1px solid #333; border-bottom: 1px solid #333;
                  padding: 6px 0; margin: 4px 0 3px; }
    .cena-traka .lbl { font-size: 8.5pt; color: #555; }
    .cena-traka .iznos-mali { font-size: 12pt; font-weight: bold; color: #1a237e; }
    .cena-traka .nalog-br { font-size: 9.5pt; }
    .cena-traka .nalog-br strong { color: #1a237e; }
    .uslovi-placanja { font-size: 8.5pt; color: #444; margin-bottom: 8px; }

    .uslovi-naslov { font-size: 11pt; font-weight: bold; text-align: center;
                     margin-bottom: 8px; border-bottom: 1px solid #333; padding-bottom: 4px; }
    .uslovi-text { font-size: 8.1pt; line-height: 1.4; color: #222; }
    .uslovi-text p { margin-bottom: 4px; }
    .uslovi-text strong { font-weight: bold; }
    .uslovi-text .uslovi-stavka { padding-left: 12px; position: relative; }
    .uslovi-text .uslovi-stavka::before { content: "•"; position: absolute; left: 2px; color: #555; }
    .uslovi-text .uslovi-naglasak { font-weight: bold; text-align: center; margin-top: 6px; }

    .no-print { margin-top: 20px; text-align: center; padding-bottom: 16px; }
    .no-print button { padding: 6px 18px; font-size: 10pt; cursor: pointer; border: 1px solid #999;
                       border-radius: 4px; background: #f0f0f0; margin: 0 4px; }
    .no-print button:hover { background: #e0e0e0; }
    .loading { padding: 60px; text-align: center; font-size: 12pt; color: #666; }

    /* ── Logo + zaglavlje ── */
    .print-header { display: flex; align-items: flex-start; gap: 15px; margin-bottom: 16px; }
    .print-logo { width: 100px; height: 100px; object-fit: contain; flex-shrink: 0; }
    .print-firma-podaci { flex-grow: 1; }
    .print-doc-meta { text-align: right; flex-shrink: 0; min-width: 180px; }
    .print-doc-meta .doc-title { font-size: 13pt; font-weight: bold; letter-spacing: 1px;
                                  border-top: 2px solid #000; border-bottom: 2px solid #000;
                                  padding: 4px 0; margin-bottom: 6px; }
    .print-doc-meta .doc-line { font-size: 9.5pt; line-height: 1.7; }
    .print-doc-meta .doc-line strong { color: #1a237e; }

    /* @@page { margin: 0 } uklanja prostor u kome browser ispisuje URL/datum/broj strane */
    @@page { margin: 0; }

    @@media print {
        .no-print { display: none !important; }
        body { font-size: 9pt; }
        .wrap { padding: 14mm 16mm; }
        .print-logo { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    }
</style>

@if (_ucitava)
{
    <div class="loading">Učitavanje...</div>
}
else if (_nalog is null)
{
    <div class="loading" style="color:#c62828;">Nalog nije pronađen.<br /><br /><button onclick="window.history.back()">Nazad</button></div>
}
else
{

@* ══════════════════════════════════════════════
   STRANA 1: NALOG ZA TRANSPORT
   ══════════════════════════════════════════════ *@
<div class="wrap">

    @* Zaglavlje: logo + firma levo, doc info desno *@
    <div class="print-header">

        @if (!string.IsNullOrEmpty(_logoBase64))
        {
            <img src="@_logoBase64" class="print-logo" alt="Logo" />
        }

        <div class="print-firma-podaci firm-block">
            @if (_firma is not null)
            {
                <div class="naziv">@_firma.NazivFirme</div>
                <div>@_firma.Adresa, @_firma.PosBroj @_firma.Mesto</div>
                <div>PIB: @_firma.PIB &nbsp;&nbsp; MB: @_firma.MaticniBroj</div>
                @if (!string.IsNullOrWhiteSpace(_firma.Telefon))
                { <div>Tel: @_firma.Telefon</div> }
                @if (!string.IsNullOrWhiteSpace(_firma.mail))
                { <div>@_firma.mail</div> }
            }
        </div>

        <div class="print-doc-meta">
            <div class="doc-title">NALOG ZA TRANSPORT</div>
            <div class="doc-line">Broj: <strong>@_nalog.BrNaloga</strong></div>
            @if (!string.IsNullOrWhiteSpace(_nalog.BrTure))
            { <div class="doc-line">Tura: <strong>@_nalog.BrTure</strong></div> }
            <div class="doc-line">Datum: @_nalog.DatumDokumenta?.ToString("dd.MM.yyyy")</div>
        </div>

    </div>

    @* Nalogodavac + Prevoznik *@
    <div class="two-col">
        <div class="blok">
            <div class="naslov">Nalogodavac (stranka)</div>
            <div class="vrednost">@(_nalogodavac?.Naziv ?? _nalog.Uvoznik ?? "—")</div>
            @if (_nalogodavac is not null)
            {
                @if (!string.IsNullOrWhiteSpace(_nalogodavac.Adresa) || !string.IsNullOrWhiteSpace(_nalogodavac.Mesto))
                { <div class="sub">@_nalogodavac.Adresa@(!string.IsNullOrWhiteSpace(_nalogodavac.Adresa) && !string.IsNullOrWhiteSpace(_nalogodavac.Mesto) ? ", " : "")@_nalogodavac.Mesto</div> }
                @if (!string.IsNullOrWhiteSpace(_nalogodavac.PIB))
                { <div class="sub">PIB: @_nalogodavac.PIB</div> }
            }
        </div>
        <div class="blok">
            <div class="naslov">Prevoznik</div>
            <div class="vrednost">@(_prevoznik?.Naziv ?? _nalog.Napomena2 ?? (_firma?.NazivFirme ?? "SOPSTVENI"))</div>
            @if (_prevoznik is not null)
            {
                @if (!string.IsNullOrWhiteSpace(_prevoznik.Adresa) || !string.IsNullOrWhiteSpace(_prevoznik.Mesto))
                { <div class="sub">@_prevoznik.Adresa@(!string.IsNullOrWhiteSpace(_prevoznik.Adresa) && !string.IsNullOrWhiteSpace(_prevoznik.Mesto) ? ", " : "")@_prevoznik.Mesto</div> }
                @if (!string.IsNullOrWhiteSpace(_prevoznik.PIB))
                { <div class="sub">PIB: @_prevoznik.PIB</div> }
            }
            @if (!string.IsNullOrWhiteSpace(_nalog.Vozac))
            { <div class="sub">Vozač: @_nalog.Vozac</div> }
            @if (!string.IsNullOrWhiteSpace(_nalog.Vozilo))
            { <div class="sub">Vozilo: @_nalog.Vozilo</div> }
        </div>
    </div>

    @* Utovarna / Istovarna stanica *@
    <div class="two-col">
        <div class="blok">
            <div class="naslov">Mesto utovara</div>
            <div class="vrednost">@(_nalog.MestoUtovara ?? "—")</div>
            @if (!string.IsNullOrWhiteSpace(_nalog.AdresaUtovara))
            { <div class="sub">@_nalog.AdresaUtovara</div> }
            @if (_nalog.DatumUtovara.HasValue)
            { <div class="sub">Datum: @_nalog.DatumUtovara.Value.ToString("dd.MM.yyyy")</div> }
        </div>
        <div class="blok">
            <div class="naslov">Mesto istovara</div>
            <div class="vrednost">@(_nalog.MestoIstovara ?? "—")</div>
            @if (!string.IsNullOrWhiteSpace(_nalog.AdresaIstovara))
            { <div class="sub">@_nalog.AdresaIstovara</div> }
            @if (_nalog.DatumIstovara.HasValue)
            { <div class="sub">Datum: @_nalog.DatumIstovara.Value.ToString("dd.MM.yyyy")</div> }
        </div>
    </div>

    @* Carinjenje — zasebne kocke, prikazuju se samo ako ima teksta *@
    @if (!string.IsNullOrWhiteSpace(_nalog.IzvoznoCarinjenje))
    {
        <div class="blok" style="margin-bottom:10px;">
            <div class="naslov">Izvozno carinjenje</div>
            <div class="vrednost" style="font-size:9.5pt; font-weight:normal;">@_nalog.IzvoznoCarinjenje</div>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(_nalog.UvoznoCarinjenje))
    {
        <div class="blok" style="margin-bottom:10px;">
            <div class="naslov">Uvozno carinjenje</div>
            <div class="vrednost" style="font-size:9.5pt; font-weight:normal;">@_nalog.UvoznoCarinjenje</div>
        </div>
    }

    @* Podaci o robi *@
    @if (!string.IsNullOrWhiteSpace(_nalog.PodaciORobi))
    {
        <div class="blok" style="margin-bottom:10px;">
            <div class="naslov">Podaci o robi / Roba</div>
            <div class="vrednost" style="font-size:9.5pt; font-weight:normal; white-space:pre-wrap;">@_nalog.PodaciORobi</div>
        </div>
    }

    @* Dokumentacija + Kontakt *@
    <div class="two-col">
        <div>
            @if (!string.IsNullOrWhiteSpace(_nalog.CMR) || !string.IsNullOrWhiteSpace(_nalog.Nalog))
            {
                <div class="blok">
                    <div class="naslov">Dokumentacija</div>
                    @if (!string.IsNullOrWhiteSpace(_nalog.CMR))
                    { <div class="info-row"><span class="lbl">CMR broj:</span><span class="val">@_nalog.CMR</span></div> }
                    @if (!string.IsNullOrWhiteSpace(_nalog.Nalog))
                    { <div class="info-row"><span class="lbl">Ref. nalog klijenta:</span><span class="val">@_nalog.Nalog</span></div> }
                </div>
            }
        </div>
        <div>
            @* Kontakt *@
            @if (!string.IsNullOrWhiteSpace(_nalog.Kontakt))
            {
                <div class="blok">
                    <div class="naslov">Kontakt</div>
                    <div class="vrednost" style="font-weight:normal; font-size:9.5pt;">@_nalog.Kontakt</div>
                </div>
            }
        </div>
    </div>

    @* Napomena *@
    @if (!string.IsNullOrWhiteSpace(_nalog.Napomena1))
    {
        <div style="margin-bottom:10px;">
            <div style="font-size:8.5pt; font-weight:bold; color:#555; margin-bottom:3px;">NAPOMENA:</div>
            <div class="napomena-box">@_nalog.Napomena1</div>
        </div>
    }

    @* Klauzule *@
    <div style="font-size:8pt; color:#555; margin-top:6px; border-top:1px dashed #ccc; padding-top:6px;">
        Prevoz se vrši prema CMR Konvenciji i opštim uslovima prevoza. Uslovi na poleđini naloga.
    </div>

</div>

@* ══════════════════════════════════════════════
   STRANA 2: USLOVI PREVOZA
   ══════════════════════════════════════════════ *@
<div class="wrap page-break">

    @* Zaglavlje: logo + firma (isto kao prva strana) *@
    <div class="print-header">

        @if (!string.IsNullOrEmpty(_logoBase64))
        {
            <img src="@_logoBase64" class="print-logo" alt="Logo" />
        }

        <div class="print-firma-podaci firm-block">
            @if (_firma is not null)
            {
                <div class="naziv">@_firma.NazivFirme</div>
                <div>@_firma.Adresa, @_firma.PosBroj @_firma.Mesto</div>
                <div>PIB: @_firma.PIB &nbsp;&nbsp; MB: @_firma.MaticniBroj</div>
            }
        </div>

        <div class="print-doc-meta">
            <div class="doc-title">NALOG ZA TRANSPORT</div>
            <div class="doc-line">Broj: <strong>@_nalog.BrNaloga</strong></div>
        </div>

    </div>

    @* Cena transporta + uslovi plaćanja *@
    <div class="cena-traka">
        <div><span class="lbl">Cena transporta:</span> <span class="iznos-mali">@CenaTransportaZaStampu?.ToString("N2") @(_nalog.ValutaTure?.Contains("RSD") == true ? "RSD" : "EUR")</span></div>
        <div class="nalog-br"><span class="lbl">Nalog:</span> <strong>@_nalog.BrNaloga</strong></div>
    </div>
    @if (!string.IsNullOrWhiteSpace(_nalog.UsloviPlacanja))
    {
        <div class="uslovi-placanja"><span class="lbl">Uslovi plaćanja:</span> @_nalog.UsloviPlacanja</div>
    }

    <div class="uslovi-naslov">OPŠTI USLOVI NALOGA</div>

    <div class="uslovi-text">
        @foreach (var (vrsta, red) in ParsirajUslove(_usloviTransporta))
        {
            if (vrsta == LinijaUslova.Stavka)
            {
                <p class="uslovi-stavka">@red</p>
            }
            else if (vrsta == LinijaUslova.Naglasak)
            {
                <p class="uslovi-naglasak">@red</p>
            }
            else
            {
                <p>@red</p>
            }
        }
    </div>

</div>

<div class="no-print">
    <button onclick="window.print()">🖨 Štampaj</button>
    <button onclick="window.close()">✕ Zatvori</button>
</div>

}

@code {
    [Parameter] public int IdNaloga { get; set; }

    private NalogPrevoz? _nalog;
    private PodaciFirme? _firma;
    private Partner?     _prevoznik;
    private Partner?     _nalogodavac;
    private bool         _ucitava   = true;
    private string?      _logoBase64;
    private string?      _usloviTransporta;

    // AGENCIJSKI → plaća se prevozniku (placenTransport), SOPSTVENI → mi naplaćujemo (cenaTransporta)
    private decimal? CenaTransportaZaStampu =>
        _nalog?.TipNaloga == "AGENCIJSKI" ? _nalog.PlacenTransport : _nalog?.CenaTransporta;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (!TenantService.IsAuthenticated()) { Nav.NavigateTo("/login"); return; }

        try
        {
            _firma = await Db.PodaciFirme.FirstOrDefaultAsync();
            _nalog = await Db.NaloziZaPrevoz
                              .IgnoreQueryFilters()
                              .AsNoTracking()
                              .FirstOrDefaultAsync(n => n.IdNaloga == IdNaloga);

            if (_nalog?.IdPartnera is int idPrevoznika)
            {
                _prevoznik = await Db.Partneri.AsNoTracking()
                                              .FirstOrDefaultAsync(p => p.Broj == idPrevoznika);
            }
            if (_nalog?.IdUvoznika is int idNalogodavca)
            {
                _nalogodavac = await Db.Partneri.AsNoTracking()
                                                .FirstOrDefaultAsync(p => p.Broj == idNalogodavca);
            }

            // Logo: učitaj samo ako je aktiviran u podešavanjima
            var pod = await Db.Podesavanja.AsNoTracking().FirstOrDefaultAsync();
            if (_firma?.logoData is { Length: > 0 } && pod?.stampaLogoAktivan == 1)
            {
                var mime = _firma.logoMimeType ?? "image/png";
                _logoBase64 = $"data:{mime};base64,{Convert.ToBase64String(_firma.logoData)}";
            }

            _usloviTransporta = string.IsNullOrWhiteSpace(pod?.usloviTransporta)
                                ? PodrazumevaniUsloviTransporta
                                : pod!.usloviTransporta;
        }
        catch { }
        finally { _ucitava = false; StateHasChanged(); }

        if (_nalog is not null)
        {
            await Task.Delay(400);
            await JS.InvokeVoidAsync("window.print");
        }
    }

    private enum LinijaUslova { Tekst, Stavka, Naglasak }

    // Linije koje počinju sa "*" prikazuju se kao stavke (bullet), a linije
    // koje se završavaju sa "!!!" kao istaknute (centrirane, podebljane) napomene.
    private static IEnumerable<(LinijaUslova Vrsta, string Tekst)> ParsirajUslove(string? tekst)
    {
        if (string.IsNullOrWhiteSpace(tekst)) yield break;

        foreach (var linija in tekst.Replace("\r\n", "\n").Split('\n'))
        {
            var red = linija.Trim();
            if (red.Length == 0) continue;

            if (red.StartsWith('*'))
                yield return (LinijaUslova.Stavka, red.TrimStart('*', ' ').Trim());
            else if (red.EndsWith("!!!"))
                yield return (LinijaUslova.Naglasak, red);
            else
                yield return (LinijaUslova.Tekst, red);
        }
    }

    private static readonly string PodrazumevaniUsloviTransporta = string.Join('\n', new[]
    {
        "Primalac naloga prihvata sledeće uslove:",
        "* Zaštita imena poslovnih partnera mora biti zagarantovana, direktan kontakt sa našim klijentom bez našeg znanja je najstrožije zabranjen.",
        "* Pretovar, dotovar bez našeg znanja nije dozvoljen.",
        "* Eventualna nezgoda, kvar ili bilo kakvo odugovlačenje sa datumom utovara/istovara, mora nam se odmah javiti u pismenoj formi. Vozilo mora imati CMR osiguranje, u suprotnom svi naknadni troškovi ili nezgode idu na Vas. Ako nam odbiju od vozarine (2%-5%) prenećemo taj trošak na Vas. CMR osiguranje nam se mora dostaviti pre utovara. U suprotnom se ne priznaje. Plaćanje transporta nije moguće bez originala, pečatiranog i potpisanog CMR-a bez ikakvih primedbi od strane primaoca. U slučaju bilo kakvih problema odmah nas kontaktirajte.",
        "* Kamioni imaju 24 sata za utovar i 48 sati za istovar besplatno. Subota posle 16h i nedelja se ne računaju u pomenuto vreme.",
        "* Vozač mora prisustvovati utovaru/istovaru i robu primiti/predati uredno i po broju koleta prema papirima, koji moraju biti uredno pečatirani i potpisani.",
        "* Vozač je odgovoran za osovinsko opterećenje vozila i dužan je da vodi računa o pravilnom rasporedu tereta.",
        "* Za ukupno opterećenje vozila vozač ima pravo na naknadu shodno dogovoru uz original pečatiranu priznanicu.",
        "* Prilikom utovara španeri su obavezni. Vozila na utovar moraju doći ispravna i čista, sa ispravnom ceradom.",
        "* Bilo kakvi naknadni dogovori sa isporučiocem/primaocem robe, a mimo naših naloga i znanja su zabranjeni.",
        "* Bilo kakav nedostatak ili oštećenje robe od strane carinika ili špeditera MORA biti upisano u CMR, u suprotnom vozač će biti zadužen za svaki neupisani nedostatak robe.",
        "* Ako vozač dobije T5 ili TC11 dokument obavezno ga mora overiti na zadnjoj Evropskoj granici i nama ga u originalu dostaviti. EX/T dokument obavezno dostavite nama jer je to uslov za naplatu vozarine.",
        "* U slučaju da bilo koji od navedenih uslova nije zadovoljen ne možemo Vam garantovati isplatu vozarine ili nekog dela iste. U slučaju spora za obe strane nadležan je Sud u mestu izdavaoca.",
        "* Molimo Vas da ukoliko postoje dodatni troškovi (ic, pregledi i slično) da nas o istom obavestite do termina prispeća vozila. Naknadno prijavljene troškove nećemo biti u mogućnosti da prihvatimo. Račun ili priznanicu nam prosledite uz fakturu.",
        "* Ukoliko količina robe odstupa od one prema nalogu a konstatuje se na dan utovara, o istom Vas molimo da nas odmah obavestite kako bismo dogovorili dalje korake. Naknadnu promenu cene nismo u mogućnosti da prihvatimo.",
        "* Rok za dostavu originalne dokumentacije je 7 dana po realizaciji usluge.",
        "* U slučaju nedolaska na utovar ili otkazivanja ugovorenog prevoza, zaračunaćemo Vam naše troškove u iznosu od 30% od ugovorene cene prevoza.",
        "* Primalac naloga je dužan da nam u roku od 10 dana dostavi Potvrdu o rezidentnosti radi izbegavanja dvostrukog oporezivanja. U protivnom, transport neće biti plaćen, ili će cena biti umanjena prilikom plaćanja za iznos poreza od 25%.",
        "",
        "Ovu stranu naloga ne smete pokazivati na utovaru i istovaru!!!",
        "Uslovi naplate vozarine!!!",
        "Naš nalog važi i bez vaše pismene potvrde!!!",
        "Srećan put!!!",
    });
}
