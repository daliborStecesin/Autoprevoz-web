        "ZAVRSEN" => Color.Success,
        "OTKAZAN" => Color.Error,
        _         => Color.Default
    };

    private static DateTime? ParseDT(string? s) =>
        DateTime.TryParse(s, out var d) ? d : null;

    private async Task<decimal> PovuciScalar(string sql, decimal fallback)
    {
        try
        {
            var conn      = Db.Database.GetDbConnection();
            var needsOpen = conn.State != System.Data.ConnectionState.Open;
            if (needsOpen) await conn.OpenAsync();
            await using var cmd = conn.CreateCommand();
            cmd.CommandText = sql;
            var r = await cmd.ExecuteScalarAsync();
            if (needsOpen) await conn.CloseAsync();
            if (r != null && r != DBNull.Value) return Convert.ToDecimal(r);
        }
        catch { }
        return fallback;
    }
}
