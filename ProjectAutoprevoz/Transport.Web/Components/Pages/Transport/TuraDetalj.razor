    private void SinkronizujDatumeKaTuri()
    {
        if (_tura is null) return;
        _tura.DatumPolaska = ParsajDatumVreme(_polazakDatum, _polazakVreme);
        _tura.DatumIzlaska = ParsajDatumVreme(_izlazakDatum, _izlazakVreme);
        _tura.DatumUlaska  = ParsajDatumVreme(_ulazakDatum,  _ulazakVreme);
        _tura.DatumDolaska = ParsajDatumVreme(_dolazakDatum, _dolazakVreme);
        IzracunajDnevniceTure();
    }

    private static DateTime? ParsajDatumVreme(string datum, string vreme)
    {
        if (!DateTime.TryParse(datum, out var d)) return null;
        if (TimeSpan.TryParse(vreme, out var t)) d = d.Add(t);
        return d;
    }

    // ── Obračun dnevnica na turi (ista logika kao u DnevnicaDialog) ──

    private void IzracunajDnevniceTure()
    {
        if (_tura is null) return;

        var polazak = ParsajDatumVreme(_polazakDatum, _polazakVreme);
        var izlazak = ParsajDatumVreme(_izlazakDatum, _izlazakVreme);
        var ulazak  = ParsajDatumVreme(_ulazakDatum,  _ulazakVreme);
        var dolazak = ParsajDatumVreme(_dolazakDatum, _dolazakVreme);
        if (polazak is null || izlazak is null || ulazak is null || dolazak is null) return;

        var trajanjeDom = (izlazak.Value - polazak.Value) + (dolazak.Value - ulazak.Value);
        var minDom = (int)Math.Floor(trajanjeDom.TotalMinutes);
        _tura.SatiDom     = minDom / 60m;
        _tura.DnevnicaDom = IzracunajDnevnicePoMinutima(minDom);

        var trajanjeIno = ulazak.Value - izlazak.Value;
        var minIno = (int)Math.Floor(trajanjeIno.TotalMinutes);
        _tura.SatiIno     = minIno / 60m;
        _tura.DnevnicaIno = IzracunajDnevnicePoMinutima(minIno);

        _tura.SatiNaPutuDom = _tura.SatiDom;
        _tura.SatiNaPutuIno = _tura.SatiIno;
        _tura.SatiNaPutuUK  = (_tura.SatiDom ?? 0) + (_tura.SatiIno ?? 0);

        _tura.VrednostDnevnicaDom = _tura.DnevnicaDom * _tura.CenaDnevnicaDom;
        _tura.VrednostDnevnicaIno = _tura.DnevnicaIno * _tura.CenaDnevnicaIno;
    }

    private static decimal IzracunajDnevnicePoMinutima(int totalMin)
    {
        if (totalMin < 0) return -1m;
        const int M8  = 8  * 60;
        const int M12 = 12 * 60;
        const int M24 = 24 * 60;
        if (totalMin < M8)  return 0m;
        if (totalMin < M12) return 0.5m;
        int     full = totalMin / M24;
        int     rest = totalMin % M24;
        decimal res  = full;
        if      (rest >= M12) res += 1m;
        else if (rest >= M8)  res += 0.5m;
        return res;
    }

    private void IzracunajPredjeno()
    {
        if (_tura is null) return;
        _tura.Predjeno = (_tura.KmTrenutna.HasValue && _tura.KmPocetna.HasValue)
            ? _tura.KmTrenutna.Value - _tura.KmPocetna.Value
            : null;
    }

    private void IzracunajGorivo()
    {
        if (_tura is null) return;
        _tura.GorivoUtroseno = (_tura.GorivoEnd.HasValue && _tura.GorivoStart.HasValue)
            ? _tura.GorivoEnd.Value - _tura.GorivoStart.Value
            : null;
    }

