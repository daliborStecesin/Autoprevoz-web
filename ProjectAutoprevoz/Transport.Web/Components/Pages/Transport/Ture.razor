    private string TuraRowStyle(PutniNalogKamion item, int _)
    {
        if (item.IdNaloga == _selektovanaTura?.IdNaloga)
            return "background-color:#1976D2 !important; color:#fff !important; font-weight:600;";
        if (item.Brisano == 1)
            return "background-color:#eeeeee !important; color:#9e9e9e !important; text-decoration:line-through;";
        return item.Status switch
        {
            "U TOKU"      => "background-color:#ffcdd2 !important;",
            "ZAVRŠENA"    => "background-color:#ffe0b2 !important;",
            "FAKTURISANA" => "background-color:#c8e6c9 !important;",
            "ZATVORENA"   => "background-color:#eeeeee !important;",
            _             => string.Empty
        };
    }

    private string NalogRowStyle(NalogPrevoz item, int _)
        => item.IdNaloga == _selektovaniNalog?.IdNaloga
            ? "background-color:#1976D2 !important; color:#fff !important; font-weight:600;"
            : string.Empty;

    private async Task ExportExcel()
    {
        using var wb = new XLWorkbook();
        var ws = wb.Worksheets.Add("Ture");

        var headers = new[]
        {
            "Br. ture", "Vrsta", "Vozač", "Vozilo", "Relacija",
            "Polazak", "Dolazak", "Vrednost", "Status"
        };

        for (int i = 0; i < headers.Length; i++)
        {
            var h = ws.Cell(1, i + 1);
            h.Value = headers[i];
            h.Style.Font.Bold = true;
            h.Style.Font.FontColor = XLColor.White;
            h.Style.Fill.BackgroundColor = XLColor.FromHtml("#2D3E50");
        }

        int row = 2;
        foreach (var t in _ture)
        {
            ws.Cell(row, 1).Value = t.BrNaloga;
            ws.Cell(row, 2).Value = t.VrstaPrevoza;
            ws.Cell(row, 3).Value = t.Vozac1;
            ws.Cell(row, 4).Value = !string.IsNullOrWhiteSpace(t.Prikolica)
                ? $"{t.Vozilo}/{t.Prikolica}" : t.Vozilo;
            ws.Cell(row, 5).Value = t.Relacija;
            ws.Cell(row, 6).Value = t.DatumPolaska?.ToString("dd.MM.yyyy HH:mm");
            ws.Cell(row, 7).Value = t.DatumDolaska?.ToString("dd.MM.yyyy HH:mm");
            ws.Cell(row, 8).Value = (double)(t.Cena ?? 0m);
            ws.Cell(row, 9).Value = t.Status;
            row++;
        }

        ws.Columns().AdjustToContents();

        using var ms = new MemoryStream();
        wb.SaveAs(ms);
        var base64 = Convert.ToBase64String(ms.ToArray());
        await JS.InvokeVoidAsync("downloadFile", $"ture_{DateTime.Today:yyyy-MM-dd}.xlsx", base64);
    }

    private Color StatusBoja(string? status) => status switch
    {
        "U TOKU"  => Color.Warning,
        "ZAVRSEN" => Color.Success,
        "OTKAZAN" => Color.Error,
        _         => Color.Default
    };
