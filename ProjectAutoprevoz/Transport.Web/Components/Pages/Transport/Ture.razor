    // ── CRUD ──

    private async Task NovaTura()
    {
        var tipTure = _filterVrsta == "AGENCIJSKI" ? "AGENCIJSKI" : "SOPSTVENI";

        var pod     = await Db.Podesavanja.FirstOrDefaultAsync();
        bool agenc  = tipTure == "AGENCIJSKI" && pod?.koristiOdvojeneBrojeve == 1;

        int    brojac   = agenc ? (pod?.brTureAgencijski ?? 1) : (pod?.Broj_Kalkulacije ?? 1);
        string format   = agenc
            ? (pod?.formatBrojaTureAgencijski ?? "broj-godina4")
            : (pod?.formatBrojaTure           ?? "broj-godina4");
        int minCifara   = pod?.minCifaraBroja ?? 0;

        string noviBroj = BrojDokumentaService.Formatiraj(brojac, format, minCifara, DateTime.Today);

        // Provera duplikata
        bool postoji = await Db.PutniNalozi
            .AnyAsync(t => t.BrNaloga == noviBroj && t.Brisano == 0);

        if (postoji)
        {
            var izbor = await Dialog.ShowMessageBox(
                "Duplikat broja",
                $"Dokument sa brojem '{noviBroj}' već postoji. Šta želite?",
                yesText: "OSVEŽI BROJ",
                noText:  "IPAK SAČUVAJ",
                cancelText: "OTKAŽI");

            if (izbor == null) return; // OTKAŽI

            if (izbor == true) // OSVEŽI BROJ — skoči na sledeći
            {
                brojac  += 1;
                noviBroj = BrojDokumentaService.Formatiraj(brojac, format, minCifara, DateTime.Today);
            }
            // false → IPAK SAČUVAJ sa istim brojem
        }

        await KreirajTuru(noviBroj, brojac, agenc, tipTure, pod);
    }

    private async Task KreirajTuru(string brTure, int brojac, bool agencijski,
        string tipTure, Transport.Domain.Entities.Podesavanja? pod)
    {
        using var transaction = await Db.Database.BeginTransactionAsync();
        try
        {
            decimal kurs = 1;
            try { kurs = await NbsKurs.GetKursAsync(DateTime.Today); } catch { }

            var tura = new PutniNalogKamion
            {
                BrNaloga       = brTure,
                VrstaPrevoza   = tipTure,
                Status         = "U TOKU",
                DatumDokumenta = DateTime.Today,
                DatumPolaska   = DateTime.Now,
                DatumIzlaska   = DateTime.Now,
                DatumUlaska    = DateTime.Now,
                DatumDolaska   = DateTime.Now,
                KursEUR        = kurs,
                Brisano        = 0
            };

            Db.PutniNalozi.Add(tura);

            // Increment brojača (+1 posle upotrebe)
            if (pod is not null)
            {
                if (agencijski)
                    pod.brTureAgencijski = brojac + 1;
                else
                    pod.Broj_Kalkulacije = brojac + 1;
            }

            await Db.SaveChangesAsync();
            await transaction.CommitAsync();

            Nav.NavigateTo($"/transport/nalozi/{tura.IdNaloga}");
        }
        catch (Exception ex)
        {
            await transaction.RollbackAsync();
            Snackbar.Add($"Greška pri kreiranju ture: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
    }

    private async Task BrisiTuru()
    {
        if (_selektovanaTura is null) return;

        var ok = await Dialog.ShowMessageBox(
            "Brisanje ture",
            $"Da li ste sigurni da želite da obrišete turu {_selektovanaTura.BrNaloga}?\nSvi nalozi ove ture će ostati u sistemu.",
            yesText: "Da, obriši", cancelText: "Ne");

        if (ok != true) return;

        var tura = await Db.PutniNalozi.IgnoreQueryFilters()
            .FirstOrDefaultAsync(t => t.IdNaloga == _selektovanaTura.IdNaloga);

        if (tura is not null)
        {
            tura.Brisano = 1;
            await Db.SaveChangesAsync();
            Snackbar.Add($"Tura {tura.BrNaloga} obrisana.", Severity.Success);
            await OsveziListu();
        }
    }

