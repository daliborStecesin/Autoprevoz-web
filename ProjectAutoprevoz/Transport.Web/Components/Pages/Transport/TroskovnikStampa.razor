@page "/transport/troskovnik/{Id:int}"
@layout EmptyLayout
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using Transport.Domain.Entities
@using Transport.Infrastructure.Data

@inject ITenantService     TenantService
@inject TransportDbContext Db
@inject NavigationManager  Nav
@inject IJSRuntime         JS

<PageTitle>Troskovnik @(_tura?.BrNaloga ?? "...")</PageTitle>

<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Arial, Helvetica, sans-serif; font-size: 10pt; color: #000; background: #fff; }
    .wrap { padding: 20px 30px; }

    .firm-header { margin-bottom: 10px; font-size: 9pt; line-height: 1.5; }
    .firm-header .naziv { font-size: 12pt; font-weight: bold; }

    .doc-naslov { font-size: 13pt; font-weight: bold; text-align: center; border-bottom: 2px solid #000;
                  padding-bottom: 6px; margin-bottom: 12px; }

    .zaglavlje { display: flex; gap: 24px; margin-bottom: 12px; font-size: 9pt; }
    .zag-col { flex: 1; }
    .zag-row { margin-bottom: 3px; }
    .zag-row .lbl { color: #555; min-width: 120px; display: inline-block; }
    .zag-row .val { font-weight: bold; }

    .sekcija-naslov { font-size: 9.5pt; font-weight: bold; background: #e0e0e0;
                      padding: 4px 8px; margin: 10px 0 4px; border-left: 3px solid #333; }

    table { width: 100%; border-collapse: collapse; font-size: 8.5pt; margin-bottom: 6px; }
    thead th { background: #ebebeb; font-weight: bold; padding: 5px 6px; border: 1px solid #999;
               text-align: left; white-space: nowrap; }
    tbody td { padding: 4px 6px; border: 1px solid #ccc; vertical-align: top; }
    tbody tr:nth-child(even) td { background: #f9f9f9; }
    .ra { text-align: right; }
    .ca { text-align: center; }

    .obracun-box { float: right; border: 1px solid #333; padding: 10px 16px; min-width: 280px;
                   margin-top: 10px; font-size: 9pt; }
    .obracun-box .red { display: flex; justify-content: space-between; padding: 3px 0;
                        border-bottom: 1px dotted #ccc; }
    .obracun-box .red.total { font-weight: bold; border-top: 2px solid #333; border-bottom: none;
                              font-size: 10pt; color: #1a237e; margin-top: 4px; padding-top: 6px; }
    .obracun-box .red.minus { color: #c62828; }

    .potpisi { display: flex; justify-content: space-between; margin-top: 40px; font-size: 9pt; clear: both; }
    .potpisi .blok { min-width: 160px; text-align: center; }
    .potpisi .linija { border-top: 1px solid #333; margin-top: 24px; padding-top: 4px; font-size: 8.5pt; }

    .no-print { margin-top: 20px; text-align: center; padding-bottom: 16px; }
    .no-print button { padding: 6px 18px; font-size: 10pt; cursor: pointer; border: 1px solid #999;
                       border-radius: 4px; background: #f0f0f0; margin: 0 4px; }
    .no-print button:hover { background: #e0e0e0; }
    .loading { padding: 60px; text-align: center; font-size: 12pt; color: #666; }

    .print-logo { width: 100px; height: 100px; object-fit: contain; flex-shrink: 0; }

    /* @@page { margin: 0 } uklanja prostor za browser URL/datum/broj strane */
    @@page { size: A4; margin: 0; }
    @@media print {
        .no-print { display: none !important; }
        body { font-size: 9pt; }
        thead th, tbody tr:nth-child(even) td { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        .print-logo { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        .wrap { padding: 1.5cm; }
    }
</style>

@if (_ucitava)
{
    <div class="loading">Učitavanje...</div>
}
else if (_tura is null)
{
    <div class="loading" style="color:#c62828;">Tura nije pronađena.<br /><br /><button onclick="window.history.back()">Nazad</button></div>
}
else
{
<div class="wrap">

    @* ── Zaglavlje firme ── *@
    <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:14px;">
        <div style="display:flex; align-items:flex-start; gap:12px;">
            @if (!string.IsNullOrEmpty(_logoBase64))
            {
                <img src="@_logoBase64" class="print-logo" alt="Logo" />
            }
            <div class="firm-header">
                @if (_firma is not null)
                {
                    <div class="naziv">@_firma.NazivFirme</div>
                    <div>@_firma.Adresa &nbsp; @_firma.PosBroj @_firma.Mesto</div>
                    <div>PIB: @_firma.PIB &nbsp; MB: @_firma.MaticniBroj</div>
                    @if (!string.IsNullOrWhiteSpace(_firma.Telefon)) { <div>Tel: @_firma.Telefon</div> }
                }
            </div>
        </div>
        <div style="border:1px solid #333; padding:8px 16px; text-align:center;">
            <div style="font-size:8.5pt; color:#555;">Broj ture</div>
            <div style="font-size:16pt; font-weight:bold; color:#1a237e;">@_tura.BrNaloga</div>
            <div style="font-size:8.5pt; color:#555; margin-top:4px;">@(_tura.VrstaPrevoza)</div>
        </div>
    </div>

    <div class="doc-naslov">OBRAČUN TURE — PUTNI TROSKOVNIK</div>

    @* ── Podaci o turi ── *@
    <div class="zaglavlje">
        <div class="zag-col">
            <div class="zag-row"><span class="lbl">Vozač 1:</span><span class="val">@(_tura.Vozac1 ?? "—")</span></div>
            <div class="zag-row"><span class="lbl">Vozač 2:</span><span class="val">@(_tura.Vozac2 ?? "—")</span></div>
            <div class="zag-row"><span class="lbl">Vozilo:</span><span class="val">@(_tura.Vozilo ?? "—")@(string.IsNullOrWhiteSpace(_tura.Prikolica) ? "" : $" / {_tura.Prikolica}")</span></div>
            <div class="zag-row"><span class="lbl">Relacija:</span><span class="val">@(_tura.Relacija ?? "—")</span></div>
        </div>
        <div class="zag-col">
            <div class="zag-row"><span class="lbl">Polazak:</span><span class="val">@_tura.DatumPolaska?.ToString("dd.MM.yyyy HH:mm")</span></div>
            <div class="zag-row"><span class="lbl">Dolazak:</span><span class="val">@_tura.DatumDolaska?.ToString("dd.MM.yyyy HH:mm")</span></div>
            <div class="zag-row"><span class="lbl">KM pređeno:</span><span class="val">@_tura.Predjeno?.ToString("N0") km</span></div>
            <div class="zag-row"><span class="lbl">Gorivo utrošeno:</span><span class="val">@_tura.GorivoUtroseno?.ToString("N1") L</span></div>
        </div>
        <div class="zag-col">
            <div class="zag-row"><span class="lbl">Kurs EUR za turu:</span><span class="val">@_tura.KursEUR?.ToString("N4")</span></div>
            <div class="zag-row"><span class="lbl">Akontacija DOM:</span><span class="val">@_tura.AkontacijaDom?.ToString("N2") RSD</span></div>
            <div class="zag-row"><span class="lbl">Akontacija INO:</span><span class="val">@_tura.AkontacijaIno?.ToString("N2") EUR</span></div>
            <div class="zag-row"><span class="lbl">Visina dnevnice u zemlji:</span><span class="val">@_tura.CenaDnevnicaDom?.ToString("N2") RSD</span></div>
            <div class="zag-row"><span class="lbl">Visina dnevnice u inostranstvu:</span><span class="val">@_tura.CenaDnevnicaIno?.ToString("N2") EUR</span></div>
        </div>
    </div>

    @* ── Troškovi (samo gotovinski) ── *@
    @if (_troskovi.Count > 0)
    {
        <div class="sekcija-naslov">LISTA TROŠKOVA TURE (@_troskovi.Count)</div>
        <table>
            <thead>
                <tr>
                    <th style="width:110px;">Tip troška</th>
                    <th>Opis</th>
                    <th style="width:100px;" class="ra">Iznos RSD</th>
                    <th style="width:100px;" class="ra">Iznos EUR</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in _troskovi)
                {
                    <tr>
                        <td class="ca">@(t.tip ?? "—")</td>
                        <td>@(t.vrstaTroska ?? "—")</td>
                        <td class="ra">@(t.tip == "ZEMLJA" ? t.vrednost?.ToString("N2") : "")</td>
                        <td class="ra">@(t.tip == "INOSTRANSTVO" ? t.vrednostEUR?.ToString("N2") : "")</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @* ── Obračun putnog naloga ── *@
    <div class="sekcija-naslov">OBRAČUN PUTNOG NALOGA</div>
    <div class="zaglavlje">
        <div class="zag-col">
            <div class="zag-row"><span class="lbl">Datum i sat početka putovanja:</span><span class="val">@_tura.DatumPolaska?.ToString("dd.MM.yyyy HH:mm")</span></div>
            <div class="zag-row"><span class="lbl">Datum i sat prelaska granice u odlasku:</span><span class="val">@_tura.DatumIzlaska?.ToString("dd.MM.yyyy HH:mm")</span></div>
            <div class="zag-row"><span class="lbl">Datum i sat prelaska granice u dolasku:</span><span class="val">@_tura.DatumUlaska?.ToString("dd.MM.yyyy HH:mm")</span></div>
            <div class="zag-row"><span class="lbl">Datum i sat završetka putovanja:</span><span class="val">@_tura.DatumDolaska?.ToString("dd.MM.yyyy HH:mm")</span></div>
        </div>
        <div class="zag-col">
            <div class="zag-row"><span class="lbl">Sati u zemlji:</span><span class="val">@_tura.SatiDom?.ToString("N1")</span></div>
            <div class="zag-row"><span class="lbl">Broj dnevnica u zemlji:</span><span class="val">@_tura.DnevnicaDom?.ToString("N2")</span></div>
            <div class="zag-row"><span class="lbl">Sati u inostranstvu:</span><span class="val">@_tura.SatiIno?.ToString("N1")</span></div>
            <div class="zag-row"><span class="lbl">Broj dnevnica u inostranstvu:</span><span class="val">@_tura.DnevnicaIno?.ToString("N2")</span></div>
        </div>
        <div class="zag-col">
            <div class="zag-row"><span class="lbl">Pripadajući iznos dnevnica u zemlji:</span><span class="val">@_tura.VrednostDnevnicaDom?.ToString("N2") RSD</span></div>
            <div class="zag-row"><span class="lbl">Pripadajući iznos dnevnica u inostranstvu:</span><span class="val">@_tura.VrednostDnevnicaIno?.ToString("N2") EUR</span></div>
        </div>
    </div>

    @* ── Obračun isplate (gotovinski troškovi + dnevnice) ── *@
    @{
        var kurs           = (_tura.KursEUR ?? 0) > 0 ? (_tura.KursEUR ?? 1) : 1;
        var gotInoEUR      = _troskovi.Where(t => t.tip == "INOSTRANSTVO").Sum(t => t.vrednostEUR ?? 0);
        var gotDomRSD      = _troskovi.Where(t => t.tip == "ZEMLJA").Sum(t => t.vrednost ?? 0);
        var dnevniceDomRSD = _tura.VrednostDnevnicaDom ?? 0;
        var dnevniceInoEUR = _tura.VrednostDnevnicaIno ?? 0;
        var zaIsplatuEUR   = gotInoEUR + dnevniceInoEUR;
        var zaIsplatuRSD   = gotDomRSD + dnevniceDomRSD;
        var euroURSD       = zaIsplatuEUR * kurs;
        var ukupnoRSD      = zaIsplatuRSD + euroURSD;
    }
    <div class="obracun-box">
        <div style="font-weight:bold; font-size:10pt; margin-bottom:8px; border-bottom:1px solid #333; padding-bottom:4px;">OBRAČUN ISPLATE</div>
        <div class="red">
            <span>Za isplatu EUR:</span>
            <span>@zaIsplatuEUR.ToString("N2")</span>
        </div>
        <div class="red">
            <span>Za isplatu RSD:</span>
            <span>@zaIsplatuRSD.ToString("N2") &nbsp;|&nbsp; @euroURSD.ToString("N2")</span>
        </div>
        <div class="red total">
            <span>UKUPNO RSD:</span>
            <span>@ukupnoRSD.ToString("N2")</span>
        </div>
    </div>

    @* ── Potpisi ── *@
    <div class="potpisi" style="margin-top:60px;">
        <div class="blok">
            <div class="linija">Vozač 1: @(_tura.Vozac1 ?? "—")</div>
        </div>
        @if (!string.IsNullOrWhiteSpace(_tura.Vozac2))
        {
            <div class="blok">
                <div class="linija">Vozač 2: @_tura.Vozac2</div>
            </div>
        }
        <div class="blok">
            <div class="linija">Ovlašćeni potpis</div>
        </div>
    </div>

</div>

<div class="no-print">
    <button onclick="window.print()">🖨 Štampaj</button>
    <button onclick="window.close()">✕ Zatvori</button>
</div>
}

@code {
    [Parameter] public int Id { get; set; }

    private PutniNalogKamion? _tura;
    private List<Trosak>      _troskovi = [];
    private PodaciFirme?      _firma;
    private string?           _logoBase64;
    private bool              _ucitava  = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (!TenantService.IsAuthenticated()) { Nav.NavigateTo("/login"); return; }

        try
        {
            _firma = await Db.PodaciFirme.FirstOrDefaultAsync();

            var pod = await Db.Podesavanja.AsNoTracking().FirstOrDefaultAsync();
            if (_firma?.logoData is { Length: > 0 } && pod?.stampaLogoAktivan == 1)
            {
                var mime = _firma.logoMimeType ?? "image/png";
                _logoBase64 = $"data:{mime};base64,{Convert.ToBase64String(_firma.logoData)}";
            }

            _tura  = await Db.PutniNalozi.IgnoreQueryFilters()
                              .FirstOrDefaultAsync(t => t.IdNaloga == Id);

            if (_tura is not null)
            {
                _troskovi = await Db.Troskovi
                    .Where(t => t.idNaloga == Id && t.jeGotovinski == 1 && t.brisano == 0)
                    .AsNoTracking().ToListAsync();
            }
        }
        catch { }
        finally { _ucitava = false; StateHasChanged(); }

        if (_tura is not null)
        {
            await Task.Delay(400);
            await JS.InvokeVoidAsync("window.print");
        }
    }
}
