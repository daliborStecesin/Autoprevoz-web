@page "/transport/putni-nalog/{Id:int}"
@layout EmptyLayout
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using Transport.Domain.Entities
@using Transport.Infrastructure.Data

@inject ITenantService     TenantService
@inject TransportDbContext Db
@inject NavigationManager  Nav
@inject IJSRuntime         JS

<PageTitle>@(_tura is not null ? $"Putni nalog {_tura.BrNaloga}" : "Putni nalog")</PageTitle>

<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Arial, Helvetica, sans-serif; font-size: 8pt; color: #000; background: #fff; }
    .wrap { padding: 10mm 12mm; }

    .page-break { page-break-before: always; }

    /* ── Strana 1 — dvokolonski raspored ── */
    .stranica1 { display: flex; gap: 14px; align-items: flex-start; }
    .kol-leva  { flex: 0 0 calc(50% - 7px); display: flex; flex-direction: column; gap: 10px; }
    .kol-desna { flex: 0 0 calc(50% - 7px); }

    .sek-naslov { font-weight: bold; font-size: 8.5pt; margin-bottom: 3px; letter-spacing: 0.5px; }

    table.obrazac { width: 100%; border-collapse: collapse; font-size: 7.3pt; }
    table.obrazac th, table.obrazac td { border: 1px solid #333; padding: 3px 4px; text-align: center; }
    table.obrazac th { font-weight: normal; font-size: 7pt; }
    table.obrazac td { height: 18px; }
    table.obrazac td.lbl-cell { text-align: left; font-weight: 600; }

    .primedba-box { border: 1px solid #333; padding: 4px 6px; }
    .primedba-box .naslov { font-weight: bold; margin-bottom: 4px; }
    .primedba-box .linija { border-bottom: 1px solid #999; height: 14px; margin-bottom: 4px; }

    /* ── Desna strana — zvanični obrazac ── */
    .prevoz-box { float: right; border: 1px solid #333; font-size: 7.5pt; margin-bottom: 8px; }
    .prevoz-box div { padding: 2px 8px; border-bottom: 1px solid #333; }
    .prevoz-box div:last-child { border-bottom: none; }
    .prevoz-box .aktivno { font-weight: bold; background: #eef2fb; }

    .firma-naziv { text-align: center; font-size: 11pt; font-weight: bold;
                   border-bottom: 1px solid #333; padding-bottom: 3px; margin: 28px 0 2px; clear: both; }
    .firma-podnaslov { text-align: center; font-size: 6.8pt; color: #555; margin-bottom: 10px; }

    .polje { font-size: 8pt; margin-bottom: 7px; display: flex; align-items: baseline; gap: 6px; }
    .polje .lbl { color: #333; white-space: nowrap; }
    .polje .vredn { font-weight: bold; border-bottom: 1px solid #333; flex: 1; padding-bottom: 1px; min-height: 12px; }

    .serija { font-size: 8pt; font-weight: bold; margin: 6px 0; }

    .nalog-naslov     { text-align: center; font-size: 11pt; font-weight: bold; margin: 10px 0 2px; white-space: nowrap; }
    .nalog-naslov .vredn { display: inline-block; border-bottom: 1px solid #333; padding: 0 14px; white-space: nowrap; }
    .nalog-podnaslov  { text-align: center; font-size: 9pt; font-weight: bold; margin-bottom: 12px; }

    .tovarni-tekst { font-size: 7.6pt; margin: 8px 0 2px; }
    .linija-prazna { border-bottom: 1px solid #333; height: 16px; margin-bottom: 4px; }

    .mp-red { display: flex; justify-content: space-between; align-items: flex-end; margin: 18px 0 10px; font-size: 7.5pt; }
    .mp-red .mp { font-weight: bold; }

    table.vozilo-tabela { width: 100%; border-collapse: collapse; font-size: 6.8pt; margin-bottom: 8px; table-layout: fixed; }
    table.vozilo-tabela th, table.vozilo-tabela td { border: 1px solid #333; padding: 3px 4px; text-align: center; }
    table.vozilo-tabela th { font-weight: normal; }
    table.vozilo-tabela td { height: 18px; font-weight: bold; }

    .ispravnost-naslov { text-align: center; font-weight: bold; font-size: 8.5pt; margin: 10px 0 4px; }
    .ispravnost-tekst  { font-size: 7.4pt; margin-bottom: 4px; }
    .linija-mala { display: inline-block; min-width: 70px; border-bottom: 1px solid #333; }

    .potpisi-3 { display: flex; justify-content: space-between; gap: 10px; margin-top: 26px; }
    .potpis-blok { flex: 1; text-align: center; font-size: 7pt; }
    .potpis-tekst { margin-bottom: 26px; }
    .potpis-linija { border-top: 1px solid #333; }
    .potpis-oznaka { font-size: 6.6pt; color: #555; margin-top: 2px; }

    /* ── Strana 2 — evidencija ── */
    .evid-naslov { text-align: center; font-weight: bold; font-size: 11pt; margin-bottom: 12px; }
    table.evid { width: 100%; border-collapse: collapse; font-size: 7.2pt; table-layout: fixed; }
    table.evid th, table.evid td { border: 1px solid #333; padding: 2px 3px; text-align: center; overflow: hidden; }
    table.evid th { font-weight: normal; font-size: 6.8pt; }
    table.evid td { height: 26px; }
    table.evid th.vert { writing-mode: vertical-rl; transform: rotate(180deg); white-space: nowrap; padding: 3px 0; }
    table.evid tfoot td { text-align: left; font-weight: bold; font-size: 8pt; height: 22px; padding-left: 6px; }

    .napomena-blok { margin-top: 8px; border: 1px solid #333; padding: 4px 6px; }
    .napomena-blok .naslov { font-weight: bold; font-size: 8pt; margin-bottom: 6px; }
    .napomena-blok .linija { border-bottom: 1px solid #999; height: 14px; margin-bottom: 6px; }

    .no-print { margin-top: 14px; text-align: center; padding-bottom: 16px; }
    .no-print button { padding: 6px 18px; font-size: 10pt; cursor: pointer; border: 1px solid #999;
                       border-radius: 4px; background: #f0f0f0; margin: 0 4px; }
    .no-print button:hover { background: #e0e0e0; }
    .loading { padding: 60px; text-align: center; font-size: 12pt; color: #666; }

    /* @@page { size: landscape } postavlja A4 pejzaž; margin: 0 uklanja prostor za browser URL/datum/broj strane */
    @@page { size: A4 landscape; margin: 0; }

    @@media print {
        .no-print { display: none !important; }
        .wrap { padding: 8mm 10mm; }
    }
</style>

@if (_ucitava)
{
    <div class="loading">Učitavanje...</div>
}
else if (_tura is null)
{
    <div class="loading" style="color:#c62828;">Tura nije pronađena.<br /><br /><button onclick="window.history.back()">Nazad</button></div>
}
else
{

@* ══════════════════════════════════════════════
   STRANA 1: PUTNI NALOG — ZVANIČNI OBRAZAC
   ══════════════════════════════════════════════ *@
<div class="wrap">
<div class="stranica1">

    @* ── Leva strana: gorivo, zadržavanja, primedba ── *@
    <div class="kol-leva">

        <div>
            <div class="sek-naslov">GORIVO I MAZIVO</div>
            <table class="obrazac">
                <thead>
                    <tr>
                        <th colspan="2">Izdavanje goriva</th>
                        <th rowspan="2">Vrsta goriva<br />maziva</th>
                        <th rowspan="2">Litara</th>
                        <th rowspan="2">kg</th>
                        <th rowspan="2">Potpis</th>
                    </tr>
                    <tr>
                        <th>datum</th>
                        <th>mesto</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < 5; i++)
                    {
                        <tr><td></td><td></td><td></td><td></td><td></td><td></td></tr>
                    }
                    <tr><td class="lbl-cell" rowspan="3">Potrošnja</td><td>Po normi</td><td></td><td></td><td></td><td></td></tr>
                    <tr><td>stvarna</td><td></td><td></td><td></td><td></td></tr>
                    <tr><td>+ &nbsp; –</td><td></td><td></td><td></td><td></td></tr>
                </tbody>
            </table>
        </div>

        <div>
            <div class="sek-naslov">ZADRŽAVANJE IZ TEHNIČKIH RAZLOGA (Isključenje)</div>
            <table class="obrazac">
                <thead>
                    <tr>
                        <th>Datum</th>
                        <th>Mesto</th>
                        <th>radionica</th>
                        <th>Vrsta kvara</th>
                        <th>Zadržavanje<br />časova</th>
                        <th>Potpis</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < 6; i++)
                    {
                        <tr><td></td><td></td><td></td><td></td><td></td><td></td></tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="primedba-box">
            <div class="naslov">Primedba:</div>
            @for (var i = 0; i < 4; i++)
            {
                <div class="linija"></div>
            }
        </div>

    </div>

    @* ── Desna strana: zvanični obrazac putnog naloga ── *@
    <div class="kol-desna">

        <div class="prevoz-box">
            <div class="@(_tura.VrstaPrevoza != "SOPSTVENI" ? "aktivno" : "")">1. JAVNI PREVOZ</div>
            <div class="@(_tura.VrstaPrevoza == "SOPSTVENI" ? "aktivno" : "")">2. SOPSTVENI PREVOZ</div>
        </div>

        <div class="firma-naziv">@(_firma?.NazivFirme ?? "—")</div>
        <div class="firma-podnaslov">(naziv prevoznika, odnosno imaoca teretnog motornog vozila)</div>

        <div class="polje">
            <span class="lbl">Mesto</span>
            <span class="vredn">@MestoFirme</span>
        </div>
        <div class="polje">
            <span class="lbl">Datum izdavanja</span>
            <span class="vredn">@(_tura.DatumDokumenta?.ToString("dd.MM.yyyy"))</span>
            <span class="lbl">godine</span>
        </div>

        <div class="serija">Serija A</div>

        <div class="nalog-naslov">PUTNI NALOG br: <span class="vredn">@_tura.BrNaloga</span></div>
        <div class="nalog-podnaslov">ZA TERETNO MOTORNO VOZILO</div>

        <div class="polje">
            <span class="lbl">Ime i prezime vozača</span>
            <span class="vredn">@(_tura.Vozac1 ?? "")</span>
        </div>
        <div class="polje">
            <span class="lbl">Ime i prezime ostalih članova posade:</span>
            <span class="vredn">@(_tura.Vozac2 ?? "")</span>
        </div>

        <div class="polje">
            <span class="lbl">Relacija:</span>
            <span class="vredn">@(_tura.Relacija ?? "")</span>
        </div>

        <div class="tovarni-tekst">
            Broj tovarnog lista-isprave o tome šta se prevozi, koliko i za koga se prevozi
        </div>
        <div class="linija-prazna"></div>
        <div class="linija-prazna"></div>

        <div class="mp-red">
            <span class="mp">M.P.</span>
            <span>(potpis lica ovlaš. za izdavanje putnog naloga)</span>
        </div>

        <table class="vozilo-tabela">
            <colgroup>
                <col style="width:22%" /><col style="width:18%" /><col style="width:24%" /><col style="width:18%" /><col style="width:18%" />
            </colgroup>
            <thead>
                <tr>
                    <th>Marka motornog<br />vozila</th>
                    <th>Registarski<br />broj</th>
                    <th>Oznaka područja<br />gde je registrovano</th>
                    <th>Korisna<br />nosivost (t)</th>
                    <th>Sopstvena težina<br />vozila</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>@(_vozilo?.marka ?? "")</td>
                    <td>@(_vozilo?.registarskaOznaka ?? _tura.Vozilo ?? "")</td>
                    <td></td>
                    <td></td>
                    <td></td>
                </tr>
            </tbody>
        </table>

        <table class="vozilo-tabela">
            <colgroup>
                <col style="width:22%" /><col style="width:18%" /><col style="width:24%" /><col style="width:18%" /><col style="width:18%" />
            </colgroup>
            <thead>
                <tr>
                    <th>Marka priključnog<br />vozila</th>
                    <th>Registarski<br />broj</th>
                    <th>Oznaka područja<br />gde je registrovano</th>
                    <th>Korisna<br />nosivost (t)</th>
                    <th>Sopstvena težina<br />vozila</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>@(_prikolica?.marka ?? "")</td>
                    <td>@(_prikolica?.registarskaOznaka ?? _tura.Prikolica ?? "")</td>
                    <td></td>
                    <td></td>
                    <td></td>
                </tr>
            </tbody>
        </table>

        <div class="ispravnost-naslov">STANJE ISPRAVNOSTI VOZILA</div>
        <div class="ispravnost-tekst">Ispravnost vozila utvrđena je na osnovu povrde o izvršenoj kontroli tehničke</div>
        <div class="ispravnost-tekst">Ispravnost vozila br. <span class="linija-mala"></span> &nbsp; od <span class="linija-mala"></span> &nbsp; godine</div>

        <div class="potpisi-3">
            <div class="potpis-blok">
                <div class="potpis-tekst">Potpis vozača:</div>
                <div class="potpis-linija"></div>
            </div>
            <div class="potpis-blok">
                <div class="potpis-tekst">Potvrđujem da sam primio vozilo bez vidljivih nedostataka</div>
                <div class="potpis-linija"></div>
                <div class="potpis-oznaka">(Potpis vozača)</div>
            </div>
            <div class="potpis-blok">
                <div class="potpis-tekst">Potvrđujem da je vozilo tehnički ispravno za vožnju</div>
                <div class="potpis-linija"></div>
                <div class="potpis-oznaka">(potpis odg. lica za tehn. isprav. vozila)</div>
            </div>
        </div>

    </div>

</div>
</div>

@* ══════════════════════════════════════════════
   STRANA 2: EVIDENCIJA KRETANJA VOZILA
   ══════════════════════════════════════════════ *@
<div class="wrap page-break">

    <div class="evid-naslov">EVIDENCIJA O KRETANJU VOZILA, RADNOM VREMENU I PREVEZENOM TERETU</div>

    <table class="evid">
        <colgroup>
            <col style="width:5.5%" />
            <col style="width:4.5%" />
            <col style="width:18.6%" />
            <col style="width:2.6%" /><col style="width:2.6%" />
            <col style="width:2.6%" /><col style="width:2.6%" />
            <col style="width:2.6%" /><col style="width:2.6%" />
            <col style="width:2.6%" /><col style="width:2.6%" />
            <col style="width:2.6%" /><col style="width:2.6%" />
            <col style="width:4.5%" />
            <col style="width:3%" /><col style="width:3%" />
            <col style="width:2.3%" /><col style="width:2.3%" /><col style="width:2.3%" /><col style="width:2.3%" />
            <col style="width:2.3%" /><col style="width:2.3%" /><col style="width:2.3%" /><col style="width:2.3%" />
            <col style="width:3%" /><col style="width:3%" /><col style="width:3.5%" />
            <col style="width:7%" />
        </colgroup>
        <thead>
            <tr>
                <th rowspan="3">Datum</th>
                <th rowspan="3">Stanje<br />brojila</th>
                <th rowspan="3">KRETANJE VOZILA<br />mesto polaska – dolaska</th>
                <th colspan="4">VREME</th>
                <th colspan="7">STAJANJE – ZADRŽAVANJE</th>
                <th colspan="2">PREĐENO KM</th>
                <th colspan="8">PREVEZENO TERETA U KG.</th>
                <th colspan="3">IZVRŠENO t/km</th>
                <th rowspan="3">Primalac</th>
            </tr>
            <tr>
                <th colspan="2">polaska</th>
                <th colspan="2">dolaska</th>
                <th colspan="2">utovar</th>
                <th colspan="2">istovar</th>
                <th colspan="3">ostala nepredviđena</th>
                <th rowspan="2" class="vert">sa teretom</th>
                <th rowspan="2" class="vert">bez ter.</th>
                <th colspan="4">Teretno</th>
                <th colspan="4">Priključno</th>
                <th rowspan="2" class="vert">kamion</th>
                <th rowspan="2" class="vert">priključ.</th>
                <th rowspan="2" class="vert">br. sprov.</th>
            </tr>
            <tr>
                <th>čas</th><th>min</th>
                <th>čas</th><th>min</th>
                <th>čas</th><th>min</th>
                <th>čas</th><th>min</th>
                <th>čas</th><th>min</th><th>uzrok</th>
                <th class="vert">utov.</th><th class="vert">istov.</th><th class="vert">prev.</th><th class="vert">vst</th>
                <th class="vert">utov.</th><th class="vert">istov.</th><th class="vert">prev.</th><th class="vert">vst</th>
            </tr>
        </thead>
        <tbody>
            @for (var i = 0; i < 16; i++)
            {
                <tr>
                    <td></td><td></td><td></td>
                    <td></td><td></td><td></td><td></td>
                    <td></td><td></td><td></td><td></td><td></td><td></td><td></td>
                    <td></td><td></td>
                    <td></td><td></td><td></td><td></td>
                    <td></td><td></td><td></td><td></td>
                    <td></td><td></td><td></td>
                    <td></td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <td colspan="10">UKUPNO VOŽNJE čas. ……………… min ………………</td>
                <td colspan="9">Ukupno</td>
                <td colspan="9">UKUPNO:</td>
            </tr>
        </tfoot>
    </table>

    <div class="napomena-blok">
        <div class="naslov">NAPOMENA:</div>
        @for (var i = 0; i < 3; i++)
        {
            <div class="linija"></div>
        }
    </div>

</div>

<div class="no-print">
    <button onclick="window.print()">🖨 Štampaj</button>
    <button onclick="window.close()">✕ Zatvori</button>
</div>

}

@code {
    [Parameter] public int Id { get; set; }

    private PutniNalogKamion? _tura;
    private PodaciFirme?      _firma;
    private Vozilo?           _vozilo;
    private Vozilo?           _prikolica;
    private bool              _ucitava = true;

    private string MestoFirme =>
        _firma is null ? "—" :
        string.Join(", ", new[] { _firma.Mesto, _firma.Adresa }.Where(s => !string.IsNullOrWhiteSpace(s)));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (!TenantService.IsAuthenticated()) { Nav.NavigateTo("/login"); return; }

        try
        {
            _firma = await Db.PodaciFirme.AsNoTracking().FirstOrDefaultAsync();
            _tura  = await Db.PutniNalozi.IgnoreQueryFilters()
                              .AsNoTracking()
                              .FirstOrDefaultAsync(t => t.IdNaloga == Id);

            if (_tura?.IdVozila is int idVozila)
            {
                _vozilo = await Db.Vozila.AsNoTracking().FirstOrDefaultAsync(v => v.VoziloId == idVozila);
            }
            if (_tura?.IdPrikolice is int idPrikolice)
            {
                _prikolica = await Db.Vozila.AsNoTracking().FirstOrDefaultAsync(v => v.VoziloId == idPrikolice);
            }
        }
        catch { }
        finally { _ucitava = false; StateHasChanged(); }

        if (_tura is not null)
        {
            await Task.Delay(400);
            await JS.InvokeVoidAsync("window.print");
        }
    }
}
