@page "/dashboard"
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using Transport.Domain.Entities
@using Transport.Infrastructure.Data

@inject ITenantService    TenantService
@inject NavigationManager Nav
@inject TransportDbContext Db
@inject IDialogService    Dialog
@inject INbsKursService   KursService

<PageTitle>Kontrolna tabla — Autoprevoz</PageTitle>

<MudGrid Spacing="3">

    @* Leva kolona — dobrodošlica *@
    <MudItem xs="12" md="9">
        <MudText Typo="Typo.h4" Class="mb-1">
            Dobrodošli, <strong>@TenantService.GetNazivFirme()</strong>
        </MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary">
            Kontrolna tabla sistema
        </MudText>
    </MudItem>

    @* Desna kolona — Podsetnici sidebar *@
    <MudItem xs="12" md="3">
        <MudText Typo="Typo.h6" Class="mb-3">
            <MudIcon Icon="@Icons.Material.Filled.Notifications"
                     Size="Size.Small" Class="mr-1" />
            Podsetnici
        </MudText>

        @if (_ucitava)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
        }
        else if (_greska is not null)
        {
            <MudAlert Severity="Severity.Warning" Dense="true">@_greska</MudAlert>
        }
        else if (!_hitni.Any() && !_uskoro.Any())
        {
            <MudAlert Severity="Severity.Success" Dense="true">
                Nema nadolazećih obaveza
            </MudAlert>
        }
        else
        {
            @foreach (var p in _hitni)
            {
                var item = p;
                <div @onclick="@(async () => await OtvoriDetalje(item))"
                     style="cursor:pointer; margin-bottom:8px;">
                    <MudCard Elevation="1"
                             Style="border-left:4px solid var(--mud-palette-error);">
                        <MudCardContent Class="pa-3">
                            <MudText Typo="Typo.subtitle2" Color="Color.Error">
                                <b>@p.Vrsta</b>
                            </MudText>
                            <MudText Typo="Typo.body2" Class="mt-1">@p.Opis</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                                @p.DatumPotsenika?.ToString("dd.MM.yyyy")
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </div>
            }

            @foreach (var p in _uskoro)
            {
                var item = p;
                <div @onclick="@(async () => await OtvoriDetalje(item))"
                     style="cursor:pointer; margin-bottom:8px;">
                    <MudCard Elevation="1"
                             Style="border-left:4px solid #ff9800;">
                        <MudCardContent Class="pa-3">
                            <MudText Typo="Typo.subtitle2" Style="color:#e65100;">
                                <b>@p.Vrsta</b>
                            </MudText>
                            <MudText Typo="Typo.body2" Class="mt-1">@p.Opis</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                                @p.DatumPotsenika?.ToString("dd.MM.yyyy")
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </div>
            }
        }

        @* ── Važni datumi vozila ─────────────────── *@
        <MudDivider Class="my-3" />
        <MudText Typo="Typo.h6" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Filled.EventBusy" Size="Size.Small" Class="mr-1" />
            Važni datumi vozila
        </MudText>

        @if (_ucitavaVazne)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Warning" Class="mb-1" />
        }
        else if (!_vazniHitni.Any() && !_vazniUskoro.Any())
        {
            <MudAlert Severity="Severity.Success" Dense="true">
                Svi dokumenti su ažurni
            </MudAlert>
        }
        else
        {
            @foreach (var d in _vazniHitni)
            {
                <MudPaper Elevation="1" Class="pa-2 mb-1"
                          Style="border-left:3px solid var(--mud-palette-error);">
                    <MudText Typo="Typo.caption" Color="Color.Error">
                        <b>@d.RegOznaka</b> — @d.TipDokumenta
                    </MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                        Ističe @d.DatumIsteka?.ToString("dd.MM.yyyy")
                    </MudText>
                </MudPaper>
            }
            @foreach (var d in _vazniUskoro)
            {
                <MudPaper Elevation="1" Class="pa-2 mb-1"
                          Style="border-left:3px solid #ff9800;">
                    <MudText Typo="Typo.caption" Style="color:#e65100;">
                        <b>@d.RegOznaka</b> — @d.TipDokumenta
                    </MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                        Ističe @d.DatumIsteka?.ToString("dd.MM.yyyy")
                    </MudText>
                </MudPaper>
            }
        }

    </MudItem>

</MudGrid>

@* Kurs EUR — fiksno donji desni ugao *@
<div style="position:fixed; bottom:16px; right:16px; z-index:1200;">
    @if (_ucitavaKurs)
    {
        <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Default" />
    }
    else if (_kursEur > 0)
    {
        <MudPaper Elevation="3"
                  Style="padding:5px 14px; border-radius:20px; background:rgba(255,255,255,0.96);
                         border:1px solid #e0e0e0; display:flex; align-items:center; gap:6px;">
            <MudIcon Icon="@Icons.Material.Filled.CurrencyExchange"
                     Size="Size.Small" Style="color:#888; font-size:0.9rem;" />
            <MudText Style="font-size:0.78rem; color:#555; font-weight:500; white-space:nowrap;">
                EUR / RSD: @_kursEur.ToString("F2")
            </MudText>
        </MudPaper>
    }
</div>

@code {
    private List<Potsetnik> _hitni   = [];
    private List<Potsetnik> _uskoro  = [];
    private bool            _ucitava = true;
    private string?         _greska;

    private List<VazniDatumSidebar> _vazniHitni  = [];
    private List<VazniDatumSidebar> _vazniUskoro = [];
    private bool                    _ucitavaVazne;

    private record VazniDatumSidebar(string? RegOznaka, string? TipDokumenta, DateOnly? DatumIsteka);

    private decimal _kursEur;
    private bool    _ucitavaKurs;

    protected override void OnInitialized()
    {
        if (!TenantService.IsAuthenticated())
            Nav.NavigateTo("/login");
    }

    protected override async Task OnParametersSetAsync()
    {
        await Task.WhenAll(UcitajPodsetnike(), UcitajKurs(), UcitajVazneDatume());
    }

    private async Task UcitajVazneDatume()
    {
        _ucitavaVazne = true; StateHasChanged();
        try
        {
            var danas = DateOnly.FromDateTime(DateTime.Today);
            var do15  = danas.AddDays(15);
            var do30  = danas.AddDays(30);

            var svi = await Db.VazniDatumi
                .Include(d => d.Vozilo)
                .Where(d => d.datumIsteka >= danas && d.datumIsteka <= do30)
                .OrderBy(d => d.datumIsteka)
                .AsNoTracking()
                .ToListAsync();

            _vazniHitni  = svi.Where(d => d.datumIsteka <= do15)
                              .Select(d => new VazniDatumSidebar(
                                  d.Vozilo?.registarskaOznaka, d.TipDokumenta, d.datumIsteka))
                              .ToList();
            _vazniUskoro = svi.Where(d => d.datumIsteka > do15)
                              .Select(d => new VazniDatumSidebar(
                                  d.Vozilo?.registarskaOznaka, d.TipDokumenta, d.datumIsteka))
                              .ToList();
        }
        catch { }
        _ucitavaVazne = false; StateHasChanged();
    }

    private async Task UcitajKurs()
    {
        _ucitavaKurs = true; StateHasChanged();
        _kursEur     = await KursService.GetKursAsync(DateTime.Today);
        _ucitavaKurs = false; StateHasChanged();
    }

    private async Task UcitajPodsetnike()
    {
        _ucitava = true; StateHasChanged();
        try
        {
            var danas = DateOnly.FromDateTime(DateTime.Today);
            var do15  = danas.AddDays(15);
            var do30  = danas.AddDays(30);

            var svi = await Db.Podsetnici
                .Where(p => p.DatumPotsenika >= danas && p.DatumPotsenika <= do30)
                .OrderBy(p => p.DatumPotsenika)
                .ToListAsync();

            _hitni  = svi.Where(p => p.DatumPotsenika <= do15).ToList();
            _uskoro = svi.Where(p => p.DatumPotsenika >  do15).ToList();

            _ucitava = false; StateHasChanged();

            if (_hitni.Any())
                await OtvoriHitniDialog();
        }
        catch (Exception ex)
        {
            _greska  = $"Podsetnici nisu učitani: {ex.Message}";
            _ucitava = false; StateHasChanged();
        }
    }

    private async Task OtvoriHitniDialog()
    {
        var parameters = new DialogParameters<HitniPodsetnicisDialog>
        {
            { x => x.Podsetnici, _hitni }
        };
        var options = new DialogOptions
        {
            CloseButton      = true,
            MaxWidth         = MaxWidth.Small,
            FullWidth        = true,
            CloseOnEscapeKey = true
        };
        await Dialog.ShowAsync<HitniPodsetnicisDialog>("⚠️ Hitni podsetnici!", parameters, options);
    }

    private async Task OtvoriDetalje(Potsetnik p)
    {
        var opts       = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var parameters = new DialogParameters<PodsetnikDialog> { { x => x.PodsetnikId, p.IdPotsetnik } };
        var dialog     = await Dialog.ShowAsync<PodsetnikDialog>("Podsetnik", parameters, opts);
        var result     = await dialog.Result;
        if (result is { Canceled: false })
            await UcitajPodsetnike();
    }
}
