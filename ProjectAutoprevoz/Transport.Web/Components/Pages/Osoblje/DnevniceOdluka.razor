@page "/osoblje/dnevnice/odluka"
@layout EmptyLayout
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using Transport.Domain.Entities
@using Transport.Infrastructure.Data

@inject ITenantService    TenantService
@inject NavigationManager Nav
@inject TransportDbContext Db
@inject IJSRuntime        JS

<PageTitle>Odluka — Štampa</PageTitle>

<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Arial, Helvetica, sans-serif; font-size: 10.5pt; color: #000; background: #fff; }
    .wrap { padding: 28px 36px; max-width: 750px; margin: 0 auto; }

    .firm-header .naziv { font-size: 12pt; font-weight: bold; }
    .firm-header .adresa { font-size: 9pt; }

    .naslov-doc { font-size: 13pt; font-weight: bold; text-align: center;
                  margin: 24px 0 20px; border-bottom: 2px solid #000; padding-bottom: 6px; letter-spacing: 2px; }

    p { margin-bottom: 14px; line-height: 1.6; }
    .bold { font-weight: bold; }

    .mesto-datum { margin-top: 28px; font-weight: bold; }
    .potpis { text-align: right; margin-top: 40px; }
    .potpis .naziv-firme { font-weight: bold; margin-bottom: 40px; }
    .potpis .linija { border-top: 1px solid #333; width: 200px; margin-left: auto; padding-top: 4px; font-size: 9.5pt; }

    .no-print { margin-top: 32px; text-align: center; padding-bottom: 20px; }
    .no-print button { padding: 7px 22px; font-size: 10pt; cursor: pointer; border: 1px solid #999; border-radius: 4px; background: #f0f0f0; margin: 0 4px; }
    .loading { padding: 60px; text-align: center; font-size: 12pt; color: #666; }

    @@media print {
        .no-print { display: none !important; }
        body { font-size: 10pt; }
        @@page { margin: 2cm; }
    }
</style>

@if (_ucitava)
{
    <div class="loading">Učitavanje podataka...</div>
}
else if (_greska is not null)
{
    <div class="loading" style="color:#c62828;"><b>Greška:</b><br />@_greska<br /><br /><button onclick="window.close()">Zatvori</button></div>
}
else if (_dnevnica is null)
{
    <div class="loading">Dnevnica nije pronađena.</div>
}
else
{
    <div class="wrap">
        @if (_firma is not null)
        {
            <div class="firm-header">
                <div class="naziv">@_firma.NazivFirme</div>
                <div class="adresa">@_firma.Adresa &nbsp; @_firma.PosBroj @_firma.Mesto</div>
                <div class="adresa">PIB: @_firma.PIB</div>
                <div class="adresa">@_firma.MaticniBroj</div>
                @if (!string.IsNullOrEmpty(_firma.Telefon))
                {
                    <div class="adresa">Tel: @_firma.Telefon@(!string.IsNullOrEmpty(_firma.mobilni) ? "," + _firma.mobilni : "")</div>
                }
                @if (!string.IsNullOrEmpty(_firma.mail))
                {
                    <div class="adresa">e-mail: @_firma.mail</div>
                }
            </div>
        }

        <div class="naslov-doc">ODLUKA</div>

        <p>
            Upućuje se na službeni put,
            <span class="bold">@_dnevnica.vozac</span>,
            zaposleni u preduzeću <span class="bold">@(_firma?.NazivFirme ?? "")</span>,
            raspoređen na radnom mestu vozača teretnog vozila.
        </p>

        <p>
            Na službeni put se upućuje radi obavljanja radnih zadataka vozača.
        </p>

        <p>
            Službeni put se obaviti u periodu &nbsp;
            <span class="bold">@(_dnevnica.datumPolaska?.ToString("dd.MM.yyyy"))</span>
            &nbsp; do &nbsp;
            <span class="bold">@(_dnevnica.datumDolaska?.ToString("dd.MM.yyyy"))</span>
            &nbsp; godine.
        </p>

        <p>Troškovi po ovom putnom nalogu padaju na teret preduzeća</p>

        <p class="bold">@(_firma?.NazivFirme ?? "")</p>

        <p>
            Zaposlenom se odobrava isplata sredstava za namirenje troškova po realizaciji predmetnog
            službenog putovanja u iznosu
            @{
                var prikazDom = _domacaDnevnica is not null && (_domacaDnevnica.Ukupno ?? 0) > 0;
                var prikazIno = _inoDnevnica    is not null && (_inoDnevnica.Ukupno    ?? 0) > 0;
            }
            @if (prikazDom)
            {
                <span class="bold">@((_domacaDnevnica!.Ukupno ?? 0m).ToString("N2")) dinara</span>
                @if (prikazIno) { <span> i </span> }
            }
            @if (prikazIno)
            {
                <span class="bold">@((_inoDnevnica!.Ukupno ?? 0m).ToString("N2")) EUR</span>
            }
            @if (!prikazDom && !prikazIno)
            {
                <span class="bold">0,00</span>
            }
        </p>

        <p>
            Obračun po ovom putnom nalogu izvršće se po obavljenom službenom putu.
        </p>

        <div class="mesto-datum">
            @(_firma?.Mesto ?? ""), &nbsp; @(_dnevnica.datumPolaska?.ToString("dd.MM.yyyy")) &nbsp; godine.
        </div>

        <div class="potpis">
            <div class="naziv-firme">@(_firma?.NazivFirme ?? "")</div>
            <div class="linija">direktor</div>
        </div>

        <div class="no-print">
            <button onclick="window.print()">🖨 Štampaj</button>
            <button onclick="window.close()">✕ Zatvori</button>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "id")] public string? Id { get; set; }

    private Dnevnica?    _dnevnica;
    private Dnevnica?    _domacaDnevnica;
    private Dnevnica?    _inoDnevnica;
    private PodaciFirme? _firma;
    private bool         _ucitava = true;
    private string?      _greska;

    protected override void OnInitialized()
    {
        if (!TenantService.IsAuthenticated()) Nav.NavigateTo("/login");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            _firma = await Db.PodaciFirme.AsNoTracking().FirstOrDefaultAsync();

            if (!string.IsNullOrEmpty(Id) && int.TryParse(Id, out var id))
            {
                _dnevnica = await Db.Dnevnice.AsNoTracking()
                    .FirstOrDefaultAsync(x => x.IdDnevnica == id);

                if (_dnevnica is not null)
                {
                    var parovi = await Db.Dnevnice.AsNoTracking()
                        .Where(x => x.brNaloga == _dnevnica.brNaloga && x.idVozaca == _dnevnica.idVozaca)
                        .ToListAsync();
                    _domacaDnevnica = parovi.FirstOrDefault(x => x.tipDnevnice == "DOMACA");
                    _inoDnevnica    = parovi.FirstOrDefault(x => x.tipDnevnice == "INOSTRANA");
                }
            }
        }
        catch (Exception ex)
        {
            _greska = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            _ucitava = false;
            StateHasChanged();
        }

        if (_greska is null)
        {
            await Task.Delay(400);
            await JS.InvokeVoidAsync("window.print");
        }
    }
}
