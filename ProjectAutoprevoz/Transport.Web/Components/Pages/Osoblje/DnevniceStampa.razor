@page "/osoblje/dnevnice/stampa"
@layout EmptyLayout
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using Transport.Domain.Entities
@using Transport.Infrastructure.Data

@inject ITenantService    TenantService
@inject NavigationManager Nav
@inject TransportDbContext Db
@inject IJSRuntime        JS

<PageTitle>Obračun dnevnica — Štampa</PageTitle>

<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Arial, Helvetica, sans-serif; font-size: 10pt; color: #000; background: #fff; }
    .wrap { padding: 24px 32px; }

    .firm-header { margin-bottom: 16px; }
    .firm-header .naziv { font-size: 13pt; font-weight: bold; }
    .firm-header .adresa { font-size: 9pt; color: #333; }

    .two-col { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px; }
    .two-col .left { flex: 1; }
    .two-col .right { border: 1px solid #333; padding: 10px 16px; min-width: 240px; text-align: center; }
    .two-col .right .naslov { font-size: 10pt; font-weight: bold; margin-bottom: 6px; }
    .two-col .right .vozac-name { font-size: 13pt; font-weight: bold; color: #1a237e; }

    .period { font-size: 9pt; color: #333; margin-bottom: 4px; }
    .period b { color: #c62828; }

    table { width: 100%; border-collapse: collapse; font-size: 9pt; margin-top: 8px; }
    thead th { background: #e8e8e8; font-weight: bold; padding: 6px 8px; border: 1px solid #aaa; white-space: nowrap; }
    tbody td { padding: 5px 8px; border: 1px solid #ccc; vertical-align: top; }
    tbody tr:nth-child(even) td { background: #f8f8f8; }
    .right-align { text-align: right; }

    .footer-sums { margin-top: 20px; }
    .footer-sums table { width: auto; margin-left: auto; }
    .footer-sums td { padding: 4px 12px; border: 1px solid #aaa; font-weight: bold; }
    .footer-sums td:first-child { background: #e8e8e8; text-align: left; min-width: 180px; }
    .footer-sums td:last-child  { text-align: right; min-width: 120px; }

    .potpisi { display: flex; justify-content: space-between; margin-top: 40px; font-size: 9.5pt; }
    .potpisi .blok { min-width: 200px; text-align: center; }
    .potpisi .linija { border-top: 1px solid #333; margin-top: 24px; padding-top: 4px; }

    .no-print { margin-top: 24px; text-align: center; padding-bottom: 20px; }
    .no-print button { padding: 7px 22px; font-size: 10pt; cursor: pointer; border: 1px solid #999; border-radius: 4px; background: #f0f0f0; margin: 0 4px; }
    .no-print button:hover { background: #e0e0e0; }
    .loading { padding: 60px; text-align: center; font-size: 12pt; color: #666; }

    @@media print {
        .no-print { display: none !important; }
        body { font-size: 9pt; }
        thead th { background: #e8e8e8 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        tbody tr:nth-child(even) td { background: #f8f8f8 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        .footer-sums td:first-child { background: #e8e8e8 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        tr { page-break-inside: avoid; }
        @@page { margin: 1.5cm; }
    }
</style>

@if (_ucitava)
{
    <div class="loading">Učitavanje podataka...</div>
}
else if (_greska is not null)
{
    <div class="loading" style="color:#c62828;"><b>Greška:</b><br />@_greska<br /><br /><button onclick="window.close()">Zatvori</button></div>
}
else
{
    <div class="wrap">
        <div class="two-col">
            <div class="left firm-header">
                @if (_firma is not null)
                {
                    <div class="naziv">@_firma.NazivFirme</div>
                    <div class="adresa">@_firma.Adresa &nbsp; @_firma.PosBroj @_firma.Mesto</div>
                    <div class="adresa">PIB: @_firma.PIB</div>
                    <div class="adresa">Matični br: @_firma.MaticniBroj</div>
                }
            </div>
            <div class="right">
                <div class="naslov">Obračun dnevnica i gotovinskih troškova</div>
                <div>Vozač:</div>
                @if (!string.IsNullOrEmpty(_vozacIme))
                {
                    <div class="vozac-name">@_vozacIme.Replace(" ", "\n")</div>
                }
                @if (_imaDomacih && _racunDomaci is not null)
                {
                    <div style="margin-top:10px; font-size:8.5pt; color:#000; text-align:left; line-height:1.6;">
                        <div>Žiro račun: <b>@_racunDomaci.racun</b></div>
                        @if (!string.IsNullOrWhiteSpace(_racunDomaci.nazivBanke))
                        {
                            <div>Banka: @_racunDomaci.nazivBanke</div>
                        }
                    </div>
                }
                @if (_imaInostranih && _racunDevizni is not null)
                {
                    <div style="margin-top:8px; font-size:8.5pt; color:#000; text-align:left; line-height:1.6;">
                        <div>Devizni račun: <b>@_racunDevizni.racun</b></div>
                        @if (!string.IsNullOrWhiteSpace(_racunDevizni.IBAN))
                        {
                            <div>IBAN: @_racunDevizni.IBAN</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_racunDevizni.nazivBanke))
                        {
                            <div>Banka: @_racunDevizni.nazivBanke</div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="period">
            ZBIRNI OBRAČUN DNEVNICA ZA SLUŽBENA PUTOVANJA ZA PERIOD:
            <b>@FormatDatum(Od)</b> DO: <b>@FormatDatum(Do)</b>
        </div>
        <div class="period" style="color:#c62828; font-size:8pt;">(iznosi su prikazani po tipu dnevnice)</div>

        <table>
            <thead>
                <tr>
                    <th>R.b</th>
                    <th>Tip dnevnice</th>
                    <th>Relacija</th>
                    <th>Nalog</th>
                    <th>Datum polaska</th>
                    <th>Datum dolaska</th>
                    <th class="right-align">Br. dnevnica</th>
                    <th class="right-align">Vrednost dnevnice</th>
                    <th class="right-align">Ukupno</th>
                </tr>
            </thead>
            <tbody>
                @if (_dnevnice.Count == 0)
                {
                    <tr><td colspan="9" style="text-align:center; padding:16px; color:#666;">Nema dnevnica za izabrane filtere.</td></tr>
                }
                else
                {
                    int rb = 1;
                    @foreach (var d in _dnevnice)
                    {
                        <tr>
                            <td>@(rb++)</td>
                            <td>@d.tipDnevnice</td>
                            <td>@d.relacija</td>
                            <td>@d.brNaloga</td>
                            <td style="white-space:nowrap;">@d.datumPolaska?.ToString("dd.MM.yyyy HH:mm")</td>
                            <td style="white-space:nowrap;">@d.datumDolaska?.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="right-align">@d.brojDnevnica?.ToString("N2")</td>
                            <td class="right-align">@d.dnevnica?.ToString("N2")</td>
                            <td class="right-align" style="font-weight:600;">@d.Ukupno?.ToString("N2")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        <div class="footer-sums">
            <table>
                <tr>
                    <td>Domaće dnevnice:</td>
                    <td>@_sumaDomaciRSD.ToString("N2") RSD</td>
                </tr>
                <tr>
                    <td>Inostrane dnevnice:</td>
                    <td>@_sumaInoEUR.ToString("N2") EUR</td>
                </tr>
            </table>
        </div>

        <div class="potpisi">
            <div class="blok">
                <div class="linija">Zaposleni:</div>
            </div>
            <div class="blok">
                <div class="linija">Obračunao:</div>
            </div>
        </div>

        <div class="no-print">
            <button onclick="window.print()">🖨 Štampaj</button>
            <button onclick="window.close()">✕ Zatvori</button>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "od")]          public string? Od          { get; set; }
    [SupplyParameterFromQuery(Name = "do")]          public string? Do          { get; set; }
    [SupplyParameterFromQuery(Name = "idVozaca")]    public string? IdVozaca    { get; set; }
    [SupplyParameterFromQuery(Name = "tipDnevnice")] public string? TipDnevnice { get; set; }
    [SupplyParameterFromQuery(Name = "tipDatuma")]   public string? TipDatuma   { get; set; }

    private List<Dnevnica> _dnevnice     = [];
    private PodaciFirme?   _firma;
    private string?        _vozacIme;
    private VozacRacun?    _racunDomaci;
    private VozacRacun?    _racunDevizni;
    private bool           _imaDomacih;
    private bool           _imaInostranih;
    private decimal        _sumaDomaciRSD;
    private decimal        _sumaInoEUR;
    private bool           _ucitava = true;
    private string?        _greska;

    protected override void OnInitialized()
    {
        if (!TenantService.IsAuthenticated()) Nav.NavigateTo("/login");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            _firma = await Db.PodaciFirme.AsNoTracking().FirstOrDefaultAsync();

            var odDate = DateTime.TryParse(Od, out var od) ? od : new DateTime(DateTime.Today.Year, 1, 1);
            var doDate = DateTime.TryParse(Do, out var d)  ? d.AddDays(1) : DateTime.Today.AddDays(1);

            IQueryable<Dnevnica> q = Db.Dnevnice.AsNoTracking();

            if (string.IsNullOrEmpty(TipDatuma) || TipDatuma == "DATUM POLASKA")
                q = q.Where(x => x.datumPolaska >= odDate && x.datumPolaska < doDate);
            else
                q = q.Where(x => x.datumDokumenta >= odDate && x.datumDokumenta < doDate);

            if (!string.IsNullOrEmpty(IdVozaca))
            {
                q = q.Where(x => x.idVozaca == IdVozaca);
                if (int.TryParse(IdVozaca, out var idV))
                {
                    var vozac = await Db.Vozaci.AsNoTracking()
                        .Where(v => v.Broj == idV)
                        .Select(v => new { v.Ime, v.Prezime })
                        .FirstOrDefaultAsync();
                    if (vozac is not null) _vozacIme = $"{vozac.Ime} {vozac.Prezime}";

                    var racuni = await Db.VozacRacuni.AsNoTracking()
                        .Where(r => r.idVozaca == idV && r.aktivan == 1 && r.glavniRacun == 1)
                        .ToListAsync();
                    _racunDomaci  = racuni.FirstOrDefault(r => r.tipRacuna == "DOMACI");
                    _racunDevizni = racuni.FirstOrDefault(r => r.tipRacuna == "DEVIZNI");
                }
            }

            if (!string.IsNullOrEmpty(TipDnevnice))
                q = q.Where(x => x.tipDnevnice == TipDnevnice);

            _dnevnice = await q.OrderBy(x => x.datumPolaska).ToListAsync();

            _imaDomacih    = _dnevnice.Any(x => x.tipDnevnice == "DOMACA");
            _imaInostranih = _dnevnice.Any(x => x.tipDnevnice == "INOSTRANA");

            _sumaDomaciRSD = _dnevnice.Where(x => x.tipDnevnice == "DOMACA").Sum(x => x.Ukupno ?? 0);
            _sumaInoEUR    = _dnevnice.Where(x => x.tipDnevnice == "INOSTRANA").Sum(x => x.Ukupno ?? 0);
        }
        catch (Exception ex)
        {
            _greska = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            _ucitava = false;
            StateHasChanged();
        }

        if (_greska is null)
        {
            await Task.Delay(400);
            await JS.InvokeVoidAsync("window.print");
        }
    }

    private static string FormatDatum(string? d) =>
        DateTime.TryParse(d, out var dt) ? dt.ToString("dd.MM.yyyy") : (d ?? "");
}
