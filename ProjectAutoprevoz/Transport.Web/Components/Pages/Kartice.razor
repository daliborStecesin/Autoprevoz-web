@page "/finansije/duznici"
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using Transport.Domain.Entities
@using Transport.Infrastructure.Data

@inject ITenantService      TenantService
@inject NavigationManager   Nav
@inject TransportDbContext  Db
@inject IJSRuntime          JS

<PageTitle>Dužnici i dugovanja — Autoprevoz</PageTitle>

<MudText Typo="Typo.h5" Class="mb-3">
    <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Class="mr-2" />
    Dužnici i dugovanja
</MudText>

<MudPaper Elevation="1" Class="pa-3 mb-3">
    <MudTextField Value="_pretragaNaziv"
                   ValueChanged="@((string v) => { _pretragaNaziv = v; Filtriraj(); })"
                   Label="Naziv partnera" Variant="Variant.Outlined"
                   Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                   Immediate="true" Margin="Margin.Dense"
                   T="string" />
</MudPaper>

@if (_ucitava)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="false">

        @* ── TAB 1: DUŽNICI ─────────────────────────────── *@
        <MudTabPanel Text="Dužnici (izlazni)" Icon="@Icons.Material.Filled.TrendingUp">
            <MudGrid Spacing="2" Class="mt-2">
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.subtitle2" Class="mb-1">
                        Dugovanja: <strong>@_duzniciDomUk.ToString("N2") RSD</strong>
                        &nbsp;|&nbsp; Van valute: <strong>@_duzniciDomVV.ToString("N2") RSD</strong>
                    </MudText>
                    <div class="d-flex gap-2 mb-1">
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Receipt"
                                   Disabled="@(_selDuzniciDom is null)"
                                   OnClick="@(() => OtvoriKarticu(_selDuzniciDom!.Pib, "izlaz_domaci"))">
                            Prikaži karticu
                        </MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.Print"
                                   OnClick="@(() => Stampaj("duznici_dom"))">
                            Štampa
                        </MudButton>
                    </div>
                    <MudDataGrid T="PartnerSaldo" Items="_duzniciDom" Dense="true" Hover="true" Striped="true"
                                 RowStyleFunc="@((item, _) => RedStil(item, _selDuzniciDom))"
                                 RowClick="@((DataGridRowClickEventArgs<PartnerSaldo> e) => { _selDuzniciDom = e.Item; })">
                        <Columns>
                            <PropertyColumn Property="x => x.Naziv" Title="Naziv partnera" />
                            <TemplateColumn Title="Preostalo" HeaderStyle="text-align:right;">
                                <CellTemplate><span style="display:block; text-align:right;">@context.Item.Saldo.ToString("N2")</span></CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="Van valute" HeaderStyle="text-align:right;">
                                <CellTemplate><span style="display:block; text-align:right;">@context.Item.VanValute.ToString("N2")</span></CellTemplate>
                            </TemplateColumn>
                        </Columns>
                        <PagerContent>
                            <MudDataGridPager T="PartnerSaldo" />
                        </PagerContent>
                    </MudDataGrid>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.subtitle2" Class="mb-1">
                        Dugovanja INO: <strong>@_duzniciInoUk.ToString("N2") EUR</strong>
                        &nbsp;|&nbsp; Van valute: <strong>@_duzniciInoVV.ToString("N2") EUR</strong>
                    </MudText>
                    <div class="d-flex gap-2 mb-1">
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Receipt"
                                   Disabled="@(_selDuzniciIno is null)"
                                   OnClick="@(() => OtvoriKarticu(_selDuzniciIno!.Pib, "izlaz_ino"))">
                            Prikaži karticu
                        </MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.Print"
                                   OnClick="@(() => Stampaj("duznici_ino"))">
                            Štampa
                        </MudButton>
                    </div>
                    <MudDataGrid T="PartnerSaldo" Items="_duzniciIno" Dense="true" Hover="true" Striped="true"
                                 RowStyleFunc="@((item, _) => RedStil(item, _selDuzniciIno))"
                                 RowClick="@((DataGridRowClickEventArgs<PartnerSaldo> e) => { _selDuzniciIno = e.Item; })">
                        <Columns>
                            <PropertyColumn Property="x => x.Naziv" Title="Naziv partnera" />
                            <TemplateColumn Title="Preostalo" HeaderStyle="text-align:right;">
                                <CellTemplate><span style="display:block; text-align:right;">@context.Item.Saldo.ToString("N2")</span></CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="Van valute" HeaderStyle="text-align:right;">
                                <CellTemplate><span style="display:block; text-align:right;">@context.Item.VanValute.ToString("N2")</span></CellTemplate>
                            </TemplateColumn>
                        </Columns>
                        <PagerContent>
                            <MudDataGridPager T="PartnerSaldo" />
                        </PagerContent>
                    </MudDataGrid>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        @* ── TAB 2: DUGOVANJA ───────────────────────────── *@
        <MudTabPanel Text="Dugovanja (ulazni)" Icon="@Icons.Material.Filled.TrendingDown">
            <MudGrid Spacing="2" Class="mt-2">
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.subtitle2" Class="mb-1">
                        Obaveze: <strong>@_dugovanjaDomUk.ToString("N2") RSD</strong>
                        &nbsp;|&nbsp; Van valute: <strong>@_dugovanjaDomVV.ToString("N2") RSD</strong>
                    </MudText>
                    <div class="d-flex gap-2 mb-1">
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Receipt"
                                   Disabled="@(_selDugovanjaDom is null)"
                                   OnClick="@(() => OtvoriKarticu(_selDugovanjaDom!.Pib, "ulaz_domaci"))">
                            Prikaži karticu
                        </MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.Print"
                                   OnClick="@(() => Stampaj("dugovanja_dom"))">
                            Štampa
                        </MudButton>
                    </div>
                    <MudDataGrid T="PartnerSaldo" Items="_dugovanjaDom" Dense="true" Hover="true" Striped="true"
                                 RowStyleFunc="@((item, _) => RedStil(item, _selDugovanjaDom))"
                                 RowClick="@((DataGridRowClickEventArgs<PartnerSaldo> e) => { _selDugovanjaDom = e.Item; })">
                        <Columns>
                            <PropertyColumn Property="x => x.Naziv" Title="Naziv partnera" />
                            <TemplateColumn Title="Preostalo" HeaderStyle="text-align:right;">
                                <CellTemplate><span style="display:block; text-align:right;">@context.Item.Saldo.ToString("N2")</span></CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="Van valute" HeaderStyle="text-align:right;">
                                <CellTemplate><span style="display:block; text-align:right;">@context.Item.VanValute.ToString("N2")</span></CellTemplate>
                            </TemplateColumn>
                        </Columns>
                        <PagerContent>
                            <MudDataGridPager T="PartnerSaldo" />
                        </PagerContent>
                    </MudDataGrid>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.subtitle2" Class="mb-1">
                        Obaveze INO: <strong>@_dugovanjaInoUk.ToString("N2") EUR</strong>
                        &nbsp;|&nbsp; Van valute: <strong>@_dugovanjaInoVV.ToString("N2") EUR</strong>
                    </MudText>
                    <div class="d-flex gap-2 mb-1">
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Receipt"
                                   Disabled="@(_selDugovanjaIno is null)"
                                   OnClick="@(() => OtvoriKarticu(_selDugovanjaIno!.Pib, "ulaz_ino"))">
                            Prikaži karticu
                        </MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.Print"
                                   OnClick="@(() => Stampaj("dugovanja_ino"))">
                            Štampa
                        </MudButton>
                    </div>
                    <MudDataGrid T="PartnerSaldo" Items="_dugovanjaIno" Dense="true" Hover="true" Striped="true"
                                 RowStyleFunc="@((item, _) => RedStil(item, _selDugovanjaIno))"
                                 RowClick="@((DataGridRowClickEventArgs<PartnerSaldo> e) => { _selDugovanjaIno = e.Item; })">
                        <Columns>
                            <PropertyColumn Property="x => x.Naziv" Title="Naziv partnera" />
                            <TemplateColumn Title="Preostalo" HeaderStyle="text-align:right;">
                                <CellTemplate><span style="display:block; text-align:right;">@context.Item.Saldo.ToString("N2")</span></CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="Van valute" HeaderStyle="text-align:right;">
                                <CellTemplate><span style="display:block; text-align:right;">@context.Item.VanValute.ToString("N2")</span></CellTemplate>
                            </TemplateColumn>
                        </Columns>
                        <PagerContent>
                            <MudDataGridPager T="PartnerSaldo" />
                        </PagerContent>
                    </MudDataGrid>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

    </MudTabs>
}

@code {
    private class PartnerSaldo
    {
        public string Pib { get; set; } = "";
        public string Naziv { get; set; } = "";
        public decimal Saldo { get; set; }
        public decimal VanValute { get; set; }
    }

    private List<KarticaPartnera> _sve = [];
    private Dictionary<string, string> _nazivPoKljucu = [];

    private List<PartnerSaldo> _duzniciDomSve   = [];
    private List<PartnerSaldo> _duzniciInoSve   = [];
    private List<PartnerSaldo> _dugovanjaDomSve = [];
    private List<PartnerSaldo> _dugovanjaInoSve = [];

    private List<PartnerSaldo> _duzniciDom    = [];
    private List<PartnerSaldo> _duzniciIno    = [];
    private List<PartnerSaldo> _dugovanjaDom  = [];
    private List<PartnerSaldo> _dugovanjaIno  = [];

    private decimal _duzniciDomUk, _duzniciDomVV;
    private decimal _duzniciInoUk, _duzniciInoVV;
    private decimal _dugovanjaDomUk, _dugovanjaDomVV;
    private decimal _dugovanjaInoUk, _dugovanjaInoVV;

    private string _pretragaNaziv = "";
    private bool _ucitava;

    // ── Selekcija reda (highlight, dugme "Prikaži karticu") ──
    private PartnerSaldo? _selDuzniciDom;
    private PartnerSaldo? _selDuzniciIno;
    private PartnerSaldo? _selDugovanjaDom;
    private PartnerSaldo? _selDugovanjaIno;

    // Ključ grupisanja: PIB_Partnera ako postoji, inače fallback na Id_Partnera
    // (da redovi bez PIB-a ne ispadnu iz grupisanja i ne spoje se međusobno).
    private static string GrupniKljuc(KarticaPartnera k) =>
        !string.IsNullOrWhiteSpace(k.PibPartnera) ? k.PibPartnera! : $"ID:{k.IdPartnera}";

    protected override async Task OnInitializedAsync()
    {
        if (!TenantService.IsAuthenticated()) { Nav.NavigateTo("/login"); return; }
        await Ucitaj();
    }

    private async Task Ucitaj()
    {
        _ucitava = true; StateHasChanged();
        try
        {
            // Sve kartice (poštuje globalni filter brisano==0) — trenutno stanje, bez datuma
            _sve = await Db.Kartice.AsNoTracking().ToListAsync();

            _nazivPoKljucu = _sve
                .GroupBy(GrupniKljuc)
                .ToDictionary(g => g.Key, g => g.OrderByDescending(x => x.Id).First().NazivPartnera ?? "");

            _duzniciDomSve   = GrupisiSaldo(_sve, ["IZLAZ", "UPLATA"], "IZLAZ").OrderByDescending(p => p.Saldo).ToList();
            _duzniciInoSve   = GrupisiSaldo(_sve, ["INOSTRANI", "INO_UPLATA"], "INOSTRANI").OrderByDescending(p => p.Saldo).ToList();
            _dugovanjaDomSve = GrupisiSaldo(_sve, ["ULAZ", "ISPLATA"], "ULAZ").OrderBy(p => p.Saldo).ToList();
            _dugovanjaInoSve = GrupisiSaldo(_sve, ["INO_ULAZ", "INO_ISPLATA"], "INO_ULAZ").OrderBy(p => p.Saldo).ToList();

            Filtriraj();
        }
        finally
        {
            _ucitava = false;
            StateHasChanged();
        }
    }

    // Saldo partnera = SUM(Saldo) svih redova tog PIB-a (uplate su već negativne).
    // Van valute = SUM(Preostalo) SAMO redova RAČUNA (status = racunStatus), gde
    // Datum_Valute < danas AND Preostalo > 0.
    private List<PartnerSaldo> GrupisiSaldo(List<KarticaPartnera> redovi, string[] statusi, string racunStatus)
    {
        var danas = DateTime.Today;

        return redovi
            .Where(k => statusi.Contains(k.Status))
            .GroupBy(GrupniKljuc)
            .Select(g => new PartnerSaldo
            {
                Pib   = g.Key,
                Naziv = _nazivPoKljucu.TryGetValue(g.Key, out var n) ? n : (g.First().NazivPartnera ?? ""),
                Saldo = g.Sum(x => x.Saldo ?? 0),
                VanValute = g
                    .Where(x => x.Status == racunStatus
                             && x.DatumValute.HasValue && x.DatumValute.Value.Date < danas
                             && (x.Preostalo ?? 0) > 0)
                    .Sum(x => x.Preostalo ?? 0)
            })
            .ToList();
    }

    private void Filtriraj()
    {
        if (string.IsNullOrWhiteSpace(_pretragaNaziv))
        {
            _duzniciDom   = _duzniciDomSve;
            _duzniciIno   = _duzniciInoSve;
            _dugovanjaDom = _dugovanjaDomSve;
            _dugovanjaIno = _dugovanjaInoSve;
        }
        else
        {
            _duzniciDom   = _duzniciDomSve.Where(p => p.Naziv.Contains(_pretragaNaziv, StringComparison.OrdinalIgnoreCase)).ToList();
            _duzniciIno   = _duzniciInoSve.Where(p => p.Naziv.Contains(_pretragaNaziv, StringComparison.OrdinalIgnoreCase)).ToList();
            _dugovanjaDom = _dugovanjaDomSve.Where(p => p.Naziv.Contains(_pretragaNaziv, StringComparison.OrdinalIgnoreCase)).ToList();
            _dugovanjaIno = _dugovanjaInoSve.Where(p => p.Naziv.Contains(_pretragaNaziv, StringComparison.OrdinalIgnoreCase)).ToList();
        }

        _duzniciDomUk   = _duzniciDom.Sum(p => p.Saldo);   _duzniciDomVV   = _duzniciDom.Sum(p => p.VanValute);
        _duzniciInoUk   = _duzniciIno.Sum(p => p.Saldo);   _duzniciInoVV   = _duzniciIno.Sum(p => p.VanValute);
        _dugovanjaDomUk = _dugovanjaDom.Sum(p => p.Saldo); _dugovanjaDomVV = _dugovanjaDom.Sum(p => p.VanValute);
        _dugovanjaInoUk = _dugovanjaIno.Sum(p => p.Saldo); _dugovanjaInoVV = _dugovanjaIno.Sum(p => p.VanValute);
    }

    private static string RedStil(PartnerSaldo p, PartnerSaldo? selektovan) =>
        selektovan is not null && selektovan.Pib == p.Pib ? "background-color:#BBDEFB;" : "";

    private void OtvoriKarticu(string kljuc, string kontekst) =>
        Nav.NavigateTo($"/finansije/kartica?kljuc={Uri.EscapeDataString(kljuc)}&kontekst={kontekst}");

    private async Task Stampaj(string tip)
    {
        var url = $"/finansije/duznici/stampa?tip={tip}";
        if (!string.IsNullOrWhiteSpace(_pretragaNaziv))
            url += $"&pretraga={Uri.EscapeDataString(_pretragaNaziv)}";

        await JS.InvokeVoidAsync("open", url, "_blank");
    }
}
