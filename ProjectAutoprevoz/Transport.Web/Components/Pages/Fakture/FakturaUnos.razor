    // ── Stavke — dijalog za unos/izmenu ──────────────────────────────────
    private async Task OtvoriStavkaDialog(int index)
    {
        var postojeca = index >= 0 ? _stavke[index] : null;

        var prms = new DialogParameters<StavkaUnosDialog>
        {
            { x => x.Postojeca, postojeca },
            { x => x.KursEur, _kursEur },
            { x => x.TipRacuna, _tipRacuna },
            { x => x.PdvStopa, _pdvStopa },
            { x => x.Vozilo, _vozilo?.registarskaOznaka },
            { x => x.IdVozila, _vozilo?.VoziloId },
            { x => x.DatumUtovara, _datumUtovara },
            { x => x.DatumIstovara, _datumIstovara },
        };

        var opts = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dlg  = await Dialog.ShowAsync<StavkaUnosDialog>(
            index >= 0 ? "Izmena stavke" : "Unos stavke", prms, opts);

        var result = await dlg.Result;
        if (result is { Canceled: false, Data: Stavka stavka })
        {
            if (index >= 0)
                _stavke[index] = stavka;
            else
                _stavke.Add(stavka);

            AzurirajSumeGlave();
        }
    }

    private void ObrisiStavku(int index)
    {
        _stavke.RemoveAt(index);
        AzurirajSumeGlave();
    }

    private void AzurirajSumeGlave()
    {
        _osnovica = _stavke.Sum(s => s.Osnovica ?? 0);
        _pdv      = _stavke.Sum(s => s.PDV ?? 0);
        _ukupno   = _stavke.Sum(s => s.Ukupno ?? 0);
    }

    // ── Akcije — Sačuvaj / Obriši ────────────────────────────────────────
    private async Task Sacuvaj()
    {
        if (_idPartnera is null && string.IsNullOrWhiteSpace(_partnerNaziv))
        {
            Snackbar.Add("Izaberite partnera.", Severity.Warning);
            return;
        }

        if (_stavke.Count == 0)
        {
            Snackbar.Add("Dodajte bar jednu stavku.", Severity.Warning);
            return;
        }

        if (Id is null)
            await SacuvajNovi();
        else
            await SacuvajPostojeci();
    }

    // Status (legacy numerički kod): IZLAZ → "1", IZLAZ_BP → "3", INOSTRANI → "4"
    private void PopuniGlavu(Racun r)
    {
        r.DatumRacuna    = DateTime.TryParse(_datumRacuna, out var dr)   ? dr : null;
        r.DatumValute    = DateTime.TryParse(_valuta, out var dv)        ? dv : null;
        r.DatumPrometa   = DateTime.TryParse(_datumUtovara, out var du)  ? du : null;
        r.DatumPrometaDo = DateTime.TryParse(_datumIstovara, out var di) ? di : null;
        r.DatumKursa     = DateTime.TryParse(_datumKursa, out var dk)    ? dk : null;
        r.Kurs           = _kursEur;

        r.FiskIsecak = _brojNaloga;
        r.Otpremnica = _cmr;

        r.TipProdaje = _tipRacuna;
        r.UvozIzvoz  = _tipRacuna == "IZLAZ" ? null : _uvozIzvoz;
        r.TipStampe  = _tipStampe;

        r.Status = _tipRacuna switch
        {
            "IZLAZ"     => "1",
            "IZLAZ_BP"  => "3",
            "INOSTRANI" => "4",
            _           => r.Status
        };

        r.Osnovica   = _osnovica;
        r.SumaPDV    = _pdv;
        r.SumaRacuna = _ukupno;

        r.Komentar1 = _komentar1;
        r.Komentar2 = _komentar2;
        r.Komentar3 = _komentar3;

        r.Naziv      = _partnerNaziv;
        r.PIB        = _partnerPib;
        r.Adresa     = _partnerAdresa;
        r.Mesto      = _partnerMesto;
        r.IdPartnera = _idPartnera;

        r.Vozilo    = _vozilo?.registarskaOznaka;
        r.RegOznaka = _vozilo?.registarskaOznaka;
        r.IdVozila  = _vozilo?.VoziloId.ToString();

        r.Vozac    = _vozac is not null ? $"{_vozac.Ime} {_vozac.Prezime}" : null;
        r.IdVozaca = _vozac?.Broj.ToString();

        r.IdBanke = _idBanke;
    }

    private void PripremiStavkeZaUpis(List<Stavka> stavke, Racun r)
    {
        foreach (var s in stavke)
        {
            s.Broj        = 0;
            s.Id_Racuna   = r.Broj.ToString();
            s.selektor    = r.Broj.ToString();
            s.Id_Partnera = r.IdPartnera?.ToString();
            s.Tip_Prodaje = r.TipProdaje;
            s.Status      = r.Status;
            s.Datum       = r.DatumRacuna;
            s.brisano     = 0;
        }
    }

    private async Task SacuvajNovi()
    {
        try
        {
            var pod = await Db.Podesavanja.FirstOrDefaultAsync();
            bool ino = _tipRacuna == "INOSTRANI" && pod?.koristiOdvojeneInoRacune == 1;

            int    sl  = ino ? (pod?.Broj_Otpremnice ?? 1) : (pod?.Broj_Racuna ?? 1);
            string fmt = ino ? (pod?.formatBrojaInoRacuna ?? "broj-godina4") : (pod?.formatBrojaRacuna ?? "broj-godina4");
            int    min = pod?.minCifaraBroja ?? 0;
            var    datumRacuna = DateTime.TryParse(_datumRacuna, out var drTmp) ? drTmp : DateTime.Today;

            string brojRacuna = BrojDokumentaService.Formatiraj(sl, fmt, min, datumRacuna);

            bool postoji = await Db.Racuni.AnyAsync(r => r.BrojRacuna == brojRacuna && r.brisano == 0);
            if (postoji)
            {
                var izbor = await Dialog.ShowMessageBox(
                    "Duplikat broja",
                    $"Broj '{brojRacuna}' već postoji. Šta želite?",
                    yesText: "OSVEŽI BROJ", noText: "IPAK SAČUVAJ", cancelText: "OTKAŽI");
                if (izbor == null) return;
                if (izbor == true)
                    brojRacuna = BrojDokumentaService.Formatiraj(++sl, fmt, min, datumRacuna);
            }

            using var tx = await Db.Database.BeginTransactionAsync();
            try
            {
                var racun = new Racun();
                PopuniGlavu(racun);
                racun.BrojRacuna = brojRacuna;
                racun.brisano = 0;

                Db.Racuni.Add(racun);
                await Db.SaveChangesAsync();

                PripremiStavkeZaUpis(_stavke, racun);
                Db.ArtikliRacuna.AddRange(_stavke);

                await KarticaServis.UpsertIzRacuna(racun);
                await Db.SaveChangesAsync();

                if (pod is not null)
                {
                    if (ino) pod.Broj_Otpremnice = sl + 1;
                    else     pod.Broj_Racuna     = sl + 1;
                    await Db.SaveChangesAsync();
                }

                await tx.CommitAsync();
                Snackbar.Add("Račun sačuvan.", Severity.Success);

                _postojeci = racun;
                _brojRacunaPreview = racun.BrojRacuna ?? _brojRacunaPreview;
                PrebaciNaEditMod(racun.Broj);
            }
            catch
            {
                await tx.RollbackAsync();
                throw;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Greška: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
    }

    private async Task SacuvajPostojeci()
    {
        try
        {
            var dbRacun = await Db.Racuni.FirstOrDefaultAsync(r => r.Broj == Id!.Value);
            if (dbRacun is null)
            {
                Snackbar.Add("Račun nije pronađen.", Severity.Error);
                return;
            }

            using var tx = await Db.Database.BeginTransactionAsync();
            try
            {
                PopuniGlavu(dbRacun);
                // Broj_Racuna se ne menja, brojač se ne dira
                await KarticaServis.UpsertIzRacuna(dbRacun);
                await Db.SaveChangesAsync();

                var postojeceStavke = await Db.ArtikliRacuna
                    .Where(s => s.Id_Racuna == dbRacun.Broj.ToString())
                    .ToListAsync();
                foreach (var s in postojeceStavke)
                    s.brisano = 1;

                PripremiStavkeZaUpis(_stavke, dbRacun);
                Db.ArtikliRacuna.AddRange(_stavke);

                await Db.SaveChangesAsync();
                await tx.CommitAsync();

                Snackbar.Add("Račun sačuvan.", Severity.Success);

                _postojeci = dbRacun;
                StateHasChanged();
            }
            catch
            {
                await tx.RollbackAsync();
                throw;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Greška: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
    }

    private async Task Stampaj()
    {
        if (Id is null) return;
        await JS.InvokeVoidAsync("open", $"/fakture/stampa?id={Id}", "_blank");
    }

    // Posle prvog Save — ostani na formi, prebaci u EDIT mod za upravo sačuvani račun
    private void PrebaciNaEditMod(int broj)
    {
        Id = broj;
        Nav.NavigateTo($"/fakture/unos?id={broj}", replace: true);
    }

    private async Task Obrisi()
    {
        if (Id is null)
        {
            Nav.NavigateTo("/fakture");
            return;
        }

        var ok = await Dialog.ShowMessageBox(
            "Brisanje računa",
            $"Da li ste sigurni da želite da obrišete račun {_brojRacunaPreview}?",
            yesText: "Da, obriši", cancelText: "Ne");
        if (ok != true) return;

        try
        {
            var dbRacun = await Db.Racuni.FirstOrDefaultAsync(r => r.Broj == Id.Value);
            if (dbRacun is null) return;

            var greska = await KarticaServis.ObrisiIzRacuna(dbRacun.Broj);
            if (greska is not null)
            {
                Snackbar.Add(greska, Severity.Warning);
                return;
            }

            dbRacun.brisano = 1;
            await Db.SaveChangesAsync();

            Snackbar.Add("Račun obrisan.", Severity.Success);
            Nav.NavigateTo("/fakture");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Greška: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
    }
}
