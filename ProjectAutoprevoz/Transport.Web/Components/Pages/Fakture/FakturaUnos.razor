    // ── Partner autocomplete ─────────────────────────────────────────────
    private void AzurirajPartnerPredloge()
    {
        _partneriPredlozi = string.IsNullOrWhiteSpace(_partnerPretraga)
            ? [.. _sviPartneri]
            : [.. _sviPartneri.Where(p => (p.Naziv ?? "").Contains(_partnerPretraga, StringComparison.OrdinalIgnoreCase))];
