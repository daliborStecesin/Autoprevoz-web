    private void IzaberiPartnera(Partner? p)
    {
        _partner = p;
        _partnerPretraga = "";
        _partneriPredlozi = [];
        _partnerOpen = false;

        if (p is not null)
        {
            _partnerNaziv  = p.Naziv  ?? "";
            _partnerPib    = p.PIB    ?? "";
            _partnerAdresa = p.Adresa ?? "";
