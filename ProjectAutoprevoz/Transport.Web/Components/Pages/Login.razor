@page "/login"
@layout LoginLayout
@rendermode InteractiveServer

@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager Nav

<PageTitle>Prijava — Autoprevoz</PageTitle>

<div style="display:flex; justify-content:center; align-items:center; min-height:100vh; background:#f5f5f5;">
    <MudCard Style="width:420px;" Elevation="4">

        <MudCardHeader>
            <CardHeaderContent>
                <div class="d-flex align-center justify-center py-2">
                    <MudIcon Icon="@Icons.Material.Filled.LocalShipping"
                             Color="Color.Primary"
                             Style="font-size:2rem;"
                             Class="mr-2" />
                    <MudText Typo="Typo.h5" Color="Color.Primary">
                        <b>Autoprevoz</b>
                    </MudText>
                </div>
            </CardHeaderContent>
        </MudCardHeader>

        <form method="post" action="/api/auth/login-form">
            <MudCardContent>
                @if (_greska is not null)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4">
                        @_greska
                    </MudAlert>
                }

                <div class="mb-4">
                    <label class="ap-select-label">Email adresa</label>
                    <input type="email" name="email" class="ap-input" required autofocus />
                </div>

                <div class="mb-2">
                    <label class="ap-select-label">Lozinka</label>
                    <input type="password" name="password" class="ap-input" required />
                </div>
            </MudCardContent>

            <MudCardActions Class="px-4 pb-4">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           ButtonType="ButtonType.Submit">
                    Prijavi se
                </MudButton>
            </MudCardActions>
        </form>

    </MudCard>
</div>

@code {
    private string? _greska;

    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("greska", out var greska))
            _greska = greska;
    }
}
