@page "/podesavanja"
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Forms
@using Transport.Domain.Entities
@using Transport.Infrastructure.Data
@using Transport.Application.Services

@inject ITenantService    TenantService
@inject NavigationManager Nav
@inject TransportDbContext Db
@inject ISnackbar         Snackbar

<PageTitle>Podešavanja — Autoprevoz</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h5">
        <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2" />
        Podešavanja
    </MudText>
    <MudButton Variant="Variant.Filled"
               Color="Color.Success"
               StartIcon="@Icons.Material.Filled.Save"
               OnClick="Sacuvaj"
               Disabled="_ucitava">
        SAČUVAJ PODEŠAVANJA
    </MudButton>
</div>

@if (_ucitava)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_pod is not null && _firma is not null)
{
    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">

        @* ═══════════════════════════════════════════════════════
           TAB 1 — OPŠTA PODEŠAVANJA
        ═══════════════════════════════════════════════════════ *@
        <MudTabPanel Text="Opšta podešavanja" Icon="@Icons.Material.Filled.Tune">
            <MudGrid Spacing="3">

                @* Red 1: Mesto izdavanja | Dnevnica domaća ────────── *@
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_pod.MestoIzdavanja"
                                  Label="Mesto izdavanja"
                                  Variant="Variant.Outlined" ShrinkLabel="true"
                                  HelperText="Ako je prazno, koristi se mesto iz adrese firme" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudNumericField T="decimal?"
                                     @bind-Value="_pod.OpcijaDecimal1"
                                     Label="Dnevnica domaća (RSD)"
                                     Variant="Variant.Outlined" ShrinkLabel="true"
                                     Format="N2"
                                     HelperText=" " />
                </MudItem>

                @* Red 2: PDV stope | Dnevnica inostrana ───────────── *@
                <MudItem xs="12" md="6">
                    <div style="display:flex; gap:8px;">
                        <div style="flex:1;">
                            <MudNumericField T="decimal?"
                                             @bind-Value="_pod.StopaPDV"
                                             Label="Opšta stopa PDV %"
                                             Variant="Variant.Outlined" ShrinkLabel="true"
                                             Format="N2"
                                             HelperText=" " />
                        </div>
                        <div style="flex:1;">
                            <MudNumericField T="decimal?"
                                             @bind-Value="_pod.nizaStopaPDV"
                                             Label="Niža stopa PDV %"
                                             Variant="Variant.Outlined" ShrinkLabel="true"
                                             Format="N2"
                                             HelperText=" " />
                        </div>
                    </div>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudNumericField T="decimal?"
                                     @bind-Value="_pod.OpcijaDecimal2"
                                     Label="Dnevnica inostrana (EUR)"
                                     Variant="Variant.Outlined" ShrinkLabel="true"
                                     Format="N2"
                                     HelperText=" " />
                </MudItem>

                @* Red 3: Rok + Valuta osnova | Kurs EUR ────────────── *@
                <MudItem xs="12" md="6">
                    <div style="display:flex; gap:8px;">
                        <div style="flex:1;">
                            <MudNumericField T="decimal?"
                                             @bind-Value="_pod.ValutaDana"
                                             Label="Rok plaćanja (dana)"
                                             Variant="Variant.Outlined" ShrinkLabel="true"
                                             Format="N0"
                                             HelperText="Koristi se ako partner nema valutu" />
                        </div>
                        <div style="flex:1;">
                            <div style="position:relative; height:56px;">
                                <label style="position:absolute; top:-9px; left:10px; z-index:1;
                                              background:#fff; padding:0 4px;
                                              font-size:.75rem; color:rgba(0,0,0,.6); line-height:1;
                                              pointer-events:none;">
                                    Valuta se računa od
                                </label>
                                <select @bind="_pod.OpcijaString12"
                                        style="width:100%; height:100%; background:#fff; color:rgba(0,0,0,.87);
                                               border:1px solid rgba(0,0,0,.23); border-radius:4px;
                                               padding:0 12px; font-size:1rem; outline:none; cursor:pointer;
                                               appearance:auto;">
                                    <option value="PROMET">Datum prometa (istovara)</option>
                                    <option value="RACUN">Datum računa</option>
                                </select>
                            </div>
                            <div style="font-size:.75rem; color:rgba(0,0,0,.6); padding:3px 14px 0;">
                                Osnova za izračunavanje valute
                            </div>
                        </div>
                    </div>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudNumericField T="decimal?"
                                     @bind-Value="_pod.kursEur"
                                     Label="Podrazumevani kurs EUR (ako NBS nije dostupan)"
                                     Variant="Variant.Outlined" ShrinkLabel="true"
                                     Format="N4"
                                     HelperText=" " />
                </MudItem>

            </MudGrid>
        </MudTabPanel>

        @* ═══════════════════════════════════════════════════════
           TAB 2 — BROJEVI DOKUMENATA
        ═══════════════════════════════════════════════════════ *@
        <MudTabPanel Text="Brojevi dokumenata" Icon="@Icons.Material.Filled.Tag">

            @* ── Fakturisanje ──────────────────────────────────────── *@
            <MudText Typo="Typo.subtitle1" Class="mb-3 mud-text-secondary">
                <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" Class="mr-1" />
                Fakturisanje
            </MudText>

            <MudGrid Spacing="3" Class="mb-3">
                <MudItem xs="12" sm="4">
                    <MudNumericField T="int?"
                                     @bind-Value="_pod.Broj_Racuna"
                                     Label="Broj računa"
                                     Variant="Variant.Outlined" ShrinkLabel="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_pod.formatBrojaRacuna"
                                  Label="Format broja računa"
                                  Variant="Variant.Outlined" ShrinkLabel="true"
                                  Placeholder="broj-godina4"
                                  HelperText="Tokeni: broj, godina2, godina4, mesec, dan" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField Value="@(PrevBroj(_pod.Broj_Racuna, _pod.formatBrojaRacuna))"
                                  Label="Preview"
                                  Variant="Variant.Outlined" ShrinkLabel="true"
                                  ReadOnly="true" />
                </MudItem>
            </MudGrid>

            <MudGrid Spacing="3" Class="mb-3">
                <MudItem xs="12" sm="4">
                    <MudNumericField T="int?"
                                     @bind-Value="_pod.Broj_Otpremnice"
                                     Label="Broj ino računa"
                                     Variant="Variant.Outlined" ShrinkLabel="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_pod.formatBrojaInoRacuna"
                                  Label="Format ino računa"
                                  Variant="Variant.Outlined" ShrinkLabel="true"
                                  Placeholder="broj-godina4"
                                  HelperText="Tokeni: broj, godina2, godina4, mesec, dan" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField Value="@(PrevBroj(_pod.Broj_Otpremnice, _pod.formatBrojaInoRacuna))"
                                  Label="Preview ino"
                                  Variant="Variant.Outlined" ShrinkLabel="true"
                                  ReadOnly="true" />
                </MudItem>
            </MudGrid>

            <MudGrid Spacing="3" Class="mb-4">
                <MudItem xs="12" sm="4">
                    <MudNumericField T="int?"
                                     @bind-Value="_pod.Broj_Predracuna"
                                     Label="Broj predračuna"
                                     Variant="Variant.Outlined" ShrinkLabel="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_pod.formatBrojaPredracuna"
                                  Label="Format predračuna"
                                  Variant="Variant.Outlined" ShrinkLabel="true"
                                  Placeholder="broj-godina4"
                                  HelperText="Tokeni: broj, godina2, godina4, mesec, dan" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField Value="@(PrevBroj(_pod.Broj_Predracuna, _pod.formatBrojaPredracuna))"
                                  Label="Preview predračun"
                                  Variant="Variant.Outlined" ShrinkLabel="true"
                                  ReadOnly="true" />
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-4" />

            @* ── Finansijski dokumenti ─────────────────────────────── *@
            <MudText Typo="Typo.subtitle1" Class="mb-1 mud-text-secondary">
                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Small" Class="mr-1" />
                Finansijski dokumenti
            </MudText>
            <MudText Typo="Typo.caption" Class="mb-3 d-block mud-text-secondary">
                Format se podešava kasnije (npr. KO-1-2026)
            </MudText>

            <MudGrid Spacing="3" Class="mb-4">
                <MudItem xs="12" sm="4">
                    <MudNumericField T="int?"
                                     @bind-Value="_pod.Broj_Dok_1"
                                     Label="Broj knjižnog odobrenja (KO)"
                                     Variant="Variant.Outlined" ShrinkLabel="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField T="int?"
                                     @bind-Value="_pod.Broj_Dok_3"
                                     Label="Broj knjižnog zaduženja (KZ)"
                                     Variant="Variant.Outlined" ShrinkLabel="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField T="int?"
                                     @bind-Value="_pod.Broj_Dok_2"
                                     Label="Broj avansa"
                                     Variant="Variant.Outlined" ShrinkLabel="true" />
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-4" />

            @* ── Transport modul (Ture + Nalozi) ── uslovni prikaz ── *@
            @if ((_pod.transportModulAktivan ?? 1) != 0)
            {

            @* ── Ture ──────────────────────────────────────────────── *@
            <MudText Typo="Typo.subtitle1" Class="mb-3 mud-text-secondary">
                <MudIcon Icon="@Icons.Material.Filled.DriveEta" Size="Size.Small" Class="mr-1" />
                Transport — ture
            </MudText>
            <MudCheckBox T="bool"
                         Value="@((_pod.koristiOdvojeneBrojeve ?? 0) != 0)"
                         ValueChanged="@(v => _pod.koristiOdvojeneBrojeve = v ? 1 : 0)"
                         Label="Koristi odvojene brojeve za agencijske ture"
                         Class="mb-3" />

            <MudGrid Spacing="3" Class="mb-4">
                <MudItem xs="12" sm="4">
                    <MudNumericField T="int?"
                                     @bind-Value="_pod.Broj_Kalkulacije"
                                     Label="Broj ture"
                                     Variant="Variant.Outlined" ShrinkLabel="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_pod.formatBrojaTure"
                                  Label="Format broja ture"
                                  Variant="Variant.Outlined" ShrinkLabel="true"
                                  Placeholder="broj-godina4"
                                  HelperText="Tokeni: broj, godina2, godina4, mesec, dan" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField Value="@(PrevBroj(_pod.Broj_Kalkulacije, _pod.formatBrojaTure))"
                                  Label="Preview"
                                  Variant="Variant.Outlined" ShrinkLabel="true"
                                  ReadOnly="true" />
                </MudItem>
            </MudGrid>

            @if ((_pod.koristiOdvojeneBrojeve ?? 0) != 0)
            {
                <MudGrid Spacing="3" Class="mb-4">
                    <MudItem xs="12" sm="4">
                        <MudNumericField T="int?"
                                         @bind-Value="_pod.brTureAgencijski"
                                         Label="Br. agencijske ture"
                                         Variant="Variant.Outlined" ShrinkLabel="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudTextField @bind-Value="_pod.formatBrojaTureAgencijski"
                                      Label="Format agencijske ture"
                                      Variant="Variant.Outlined" ShrinkLabel="true"
                                      Placeholder="broj-godina4" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudTextField Value="@(PrevBroj(_pod.brTureAgencijski, _pod.formatBrojaTureAgencijski))"
                                      Label="Preview agencijski"
                                      Variant="Variant.Outlined" ShrinkLabel="true"
                                      ReadOnly="true" />
                    </MudItem>
                </MudGrid>
            }

            <MudDivider Class="my-3" />

            @* ── Nalozi ────────────────────────────────────────────── *@
            <MudText Typo="Typo.subtitle1" Class="mb-3 mud-text-secondary">
                <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Size="Size.Small" Class="mr-1" />
                Transport — nalozi
            </MudText>

            <MudGrid Spacing="3" Class="mb-4">
                <MudItem xs="12" sm="4">
                    <MudNumericField T="int?"
                                     @bind-Value="_pod.Broj_Gotovinskog"
                                     Label="Broj naloga"
                                     Variant="Variant.Outlined" ShrinkLabel="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_pod.formatBrojaNaloga"
                                  Label="Format broja naloga"
                                  Variant="Variant.Outlined" ShrinkLabel="true"
                                  Placeholder="broj-godina4" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField Value="@(PrevBroj(_pod.Broj_Gotovinskog, _pod.formatBrojaNaloga))"
                                  Label="Preview"
                                  Variant="Variant.Outlined" ShrinkLabel="true"
                                  ReadOnly="true" />
                </MudItem>
            </MudGrid>

            @if ((_pod.koristiOdvojeneBrojeve ?? 0) != 0)
            {
                <MudGrid Spacing="3" Class="mb-4">
                    <MudItem xs="12" sm="4">
                        <MudNumericField T="int?"
                                         @bind-Value="_pod.Broj_Dok_4"
                                         Label="Br. agencijskog naloga"
                                         Variant="Variant.Outlined" ShrinkLabel="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudTextField @bind-Value="_pod.formatBrojaNalogaAgencijski"
                                      Label="Format agencijskog naloga"
                                      Variant="Variant.Outlined" ShrinkLabel="true"
                                      Placeholder="broj-godina4" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudTextField Value="@(PrevBroj(_pod.Broj_Dok_4, _pod.formatBrojaNalogaAgencijski))"
                                      Label="Preview agencijski"
                                      Variant="Variant.Outlined" ShrinkLabel="true"
                                      ReadOnly="true" />
                    </MudItem>
                </MudGrid>
            }

            } @* kraj @if transportModulAktivan *@
            else
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
                    Transport modul (ture i nalozi) nije aktiviran u vašoj licenci.
                    Kontaktirajte DAK-SOFT za aktivaciju.
                </MudAlert>
            }

            <MudDivider Class="my-4" />

            @* ── Opšte opcije brojeva ──────────────────────────────── *@
            <MudText Typo="Typo.subtitle1" Class="mb-3 mud-text-secondary">
                <MudIcon Icon="@Icons.Material.Filled.Tune" Size="Size.Small" Class="mr-1" />
                Opšte opcije brojeva
            </MudText>

            <MudGrid Spacing="3">
                <MudItem xs="12" md="6">
                    <MudCheckBox T="bool"
                                 Value="@((_pod.automatskiBrojevi ?? 0) != 0)"
                                 ValueChanged="@(v => _pod.automatskiBrojevi = v ? 1 : 0)"
                                 Label="Automatski povećavaj brojeve pri čuvanju"
                                 Class="mb-2" />
                    <MudCheckBox T="bool"
                                 Value="@((_pod.rucniUnosBrojFakture ?? 0) != 0)"
                                 ValueChanged="@(v => _pod.rucniUnosBrojFakture = v ? 1 : 0)"
                                 Label="Dozvoli ručni unos brojeva dokumenata"
                                 Class="mb-2" />
                    <MudCheckBox T="bool"
                                 Value="@((_pod.koristiOdvojeneInoRacune ?? 0) != 0)"
                                 ValueChanged="@(v => _pod.koristiOdvojeneInoRacune = v ? 1 : 0)"
                                 Label="Koristi odvojene brojeve za ino račune"
                                 Class="mb-2" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudNumericField T="int?"
                                     @bind-Value="_pod.minCifaraBroja"
                                     Label="Minimalan broj cifara"
                                     Variant="Variant.Outlined" ShrinkLabel="true"
                                     HelperText="0 = bez nula ispred, 5 = 00001" />
                </MudItem>
            </MudGrid>

        </MudTabPanel>

        @* ═══════════════════════════════════════════════════════
           TAB 3 — IZGLED ŠTAMPE
        ═══════════════════════════════════════════════════════ *@
        <MudTabPanel Text="Izgled štampe" Icon="@Icons.Material.Filled.Print">

            @* ── Logo ─────────────────────────────────────────────── *@
            <MudPaper Elevation="1" Class="pa-4 mb-4">
                <MudText Typo="Typo.subtitle1" Class="mb-3 mud-text-secondary">
                    <MudIcon Icon="@Icons.Material.Filled.Image" Size="Size.Small" Class="mr-1" />
                    Logo firme
                </MudText>

                @if (!string.IsNullOrEmpty(_logoPreview))
                {
                    <div class="mb-3">
                        <img src="@_logoPreview"
                             alt="Logo firme"
                             style="max-height:120px; max-width:400px; border:1px solid #ddd; border-radius:4px; padding:4px;" />
                    </div>
                }

                <div class="d-flex align-center gap-3 flex-wrap">
                    <MudFileUpload T="IBrowserFile"
                                   FilesChanged="ObradiLogo"
                                   Accept=".png,.jpg,.jpeg"
                                   MaximumFileCount="1">
                        <ActivatorContent>
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Upload">
                                Odaberi logo
                            </MudButton>
                        </ActivatorContent>
                    </MudFileUpload>

                    @if (!string.IsNullOrEmpty(_logoPreview))
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.Delete"
                                   OnClick="UkloniLogo">
                            Ukloni logo
                        </MudButton>
                    }
                </div>

                <MudText Typo="Typo.caption" Class="mt-2 mud-text-secondary">
                    Prihvata .png, .jpg — max 500 KB
                </MudText>

                <MudCheckBox T="bool"
                             Value="@((_pod.stampaLogoAktivan ?? 0) != 0)"
                             ValueChanged="@(v => _pod.stampaLogoAktivan = v ? 1 : 0)"
                             Label="Prikazuj logo na štampi"
                             Class="mt-2" />
            </MudPaper>

            @* ── Tekstovi na štampi ────────────────────────────────── *@
            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.subtitle1" Class="mb-3 mud-text-secondary">
                    <MudIcon Icon="@Icons.Material.Filled.Notes" Size="Size.Small" Class="mr-1" />
                    Tekstovi na štampi
                </MudText>
                <MudTextField @bind-Value="_pod.usloviTransporta"
                              Label="Uslovi transporta"
                              Variant="Variant.Outlined" ShrinkLabel="true"
                              Lines="6"
                              HelperText="Prikazuje se na dnu nalog za prevoz"
                              Class="mb-3" />
                <MudGrid Spacing="3">
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_pod.napomenaStampa1"
                                      Label="Napomena na štampi 1"
                                      Variant="Variant.Outlined" ShrinkLabel="true"
                                      Lines="3" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_pod.napomenaStampa2"
                                      Label="Napomena na štampi 2"
                                      Variant="Variant.Outlined" ShrinkLabel="true"
                                      Lines="3" />
                    </MudItem>
                </MudGrid>
            </MudPaper>

            @* ── Fakturisanje — tekstovi ──────────────────────────── *@
            <MudPaper Elevation="1" Class="pa-4 mt-4">
                <MudText Typo="Typo.subtitle1" Class="mb-3 mud-text-secondary">
                    <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" Class="mr-1" />
                    Fakturisanje — tekstovi
                </MudText>

                <MudText Typo="Typo.caption" Class="mb-2 d-block mud-text-secondary">Domaća faktura</MudText>
                <MudTextField @bind-Value="_pod.Napomena_txt2"
                              Label="Stalna napomena na fakturi"
                              Variant="Variant.Outlined" ShrinkLabel="true"
                              Lines="4"
                              HelperText="Prikazuje se na dnu svake domaće fakture"
                              Class="mb-4" />

                <MudDivider Class="mb-4" />

                <MudText Typo="Typo.caption" Class="mb-2 d-block mud-text-secondary">Inostrana faktura</MudText>
                <MudTextField @bind-Value="_pod.opcijaText1"
                              Label="Stalna napomena na ino fakturi"
                              Variant="Variant.Outlined" ShrinkLabel="true"
                              Lines="4"
                              HelperText="Prikazuje se na dnu svake ino fakture"
                              Class="mb-3" />
                <MudTextField @bind-Value="_pod.opcijaText2"
                              Label="Uputstvo za uplatu — inostrano"
                              Variant="Variant.Outlined" ShrinkLabel="true"
                              Lines="6"
                              HelperText="Kompletni bankarski podaci za ino uplatu"
                              Placeholder="@("Bank of beneficiary: Banca Intesa AD Beograd\nCity: Belgrade, Serbia\nSWIFT: DBDBRSBG\nIBAN: RS35...")" />
            </MudPaper>

        </MudTabPanel>

        @* ═══════════════════════════════════════════════════════
           TAB 4 — E-FAKTURE (samo Srbija + OpcijaInt13==1)
        ═══════════════════════════════════════════════════════ *@
        @if (_firma?.Vlasnik == "SRBIJA" && (_pod?.OpcijaInt13 ?? 0) == 1)
        {
        <MudTabPanel Text="E-fakture" Icon="@Icons.Material.Filled.CloudUpload">

            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.subtitle1" Class="mb-3 mud-text-secondary">
                    <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" Class="mr-1" />
                    E-faktura (SEF)
                </MudText>

                <MudGrid Spacing="3">
                    @* Red 1: SEF server | Datum za obračun PDV *@
                    <MudItem xs="12" sm="6">
                        <div class="mb-3">
                            <label class="ap-select-label">SEF server</label>
                            <select @bind="_pod.sefTipServera" class="ap-select">
                                <option value="DEMO">DEMO</option>
                                <option value="PRODUKCIJA">PRODUKCIJA</option>
                            </select>
                        </div>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <div class="mb-3">
                            <label class="ap-select-label">Podrazumevani datum za obračun PDV</label>
                            <select @bind="_pod.pdvDatumObracuna" class="ap-select">
                                <option value="DATUM PROMETA">DATUM PROMETA</option>
                                <option value="DATUM IZDAVANJA">DATUM IZDAVANJA</option>
                            </select>
                        </div>
                    </MudItem>
                    @* Red 2: API ključ — puna širina *@
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_pod.sefApiKey"
                                      Label="API ključ SEF"
                                      Variant="Variant.Outlined" ShrinkLabel="true"
                                      InputType="@(_sefApiPrikaz ? InputType.Text : InputType.Password)"
                                      Class="mb-3"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@(_sefApiPrikaz ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                      OnAdornmentClick="@(() => _sefApiPrikaz = !_sefApiPrikaz)" />
                    </MudItem>
                    @* Red 3: PDV kategorija | Oznaka PDV *@
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_pod.pdvKategorija"
                                      Label="PDV kategorija"
                                      Variant="Variant.Outlined" ShrinkLabel="true"
                                      Placeholder="PDV-RS-33"
                                      Class="mb-3" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_pod.pdvSlovo"
                                      Label="Oznaka PDV"
                                      Variant="Variant.Outlined" ShrinkLabel="true"
                                      Placeholder="SS"
                                      Class="mb-3" />
                    </MudItem>
                </MudGrid>

            </MudPaper>

        </MudTabPanel>
        } @* kraj @if e-fakture *@

        @* ═══════════════════════════════════════════════════════
           TAB 5 — E-OTPREMNICE (za sad skriveno — TODO)
        ═══════════════════════════════════════════════════════ *@
        @if (false) @* TODO: aktivirati kad e-otpremnica bude gotova *@
        {
        <MudTabPanel Text="E-otpremnice" Icon="@Icons.Material.Filled.LocalShipping">

            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.subtitle1" Class="mb-3 mud-text-secondary">
                    <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Small" Class="mr-1" />
                    E-Otpremnica
                </MudText>

                <MudGrid Spacing="3">
                    <MudItem xs="12" sm="6">
                        <div class="mb-3">
                            <label class="ap-select-label">E-otpremnica server</label>
                            <select @bind="_pod.eOtpremnicaTipServera" class="ap-select">
                                <option value="DEMO">DEMO</option>
                                <option value="PRODUKCIJA">PRODUKCIJA</option>
                            </select>
                        </div>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_pod.eOtpremnicaApiKey"
                                      Label="API ključ E-otpremnica"
                                      Variant="Variant.Outlined" ShrinkLabel="true"
                                      InputType="@(_eOtprApiPrikaz ? InputType.Text : InputType.Password)"
                                      Class="mb-3"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@(_eOtprApiPrikaz ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                      OnAdornmentClick="@(() => _eOtprApiPrikaz = !_eOtprApiPrikaz)" />
                    </MudItem>
                </MudGrid>

                <MudCheckBox T="bool"
                             Value="@((_pod.eOtpremnicaAktivna ?? 0) != 0)"
                             ValueChanged="@(v => _pod.eOtpremnicaAktivna = v ? 1 : 0)"
                             Label="E-otpremnica aktivna" />
            </MudPaper>

        </MudTabPanel>
        } @* kraj @if e-otpremnice *@

    </MudTabs>
}

@code {
    private Transport.Domain.Entities.Podesavanja? _pod;
    private Transport.Domain.Entities.PodaciFirme?  _firma;
    private bool   _ucitava        = true;
    private bool   _noviZapis      = false;
    private bool   _noviZapisFirma = false;
    private bool   _sefApiPrikaz   = false;
    private bool   _eOtprApiPrikaz = false;
    private string? _logoPreview;

    protected override void OnInitialized()
    {
        if (!TenantService.IsAuthenticated())
            Nav.NavigateTo("/login");
        else if (TenantService.GetPrivilegija() != 1)
            Nav.NavigateTo("/");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _pod = await Db.Podesavanja.FirstOrDefaultAsync();
        if (_pod is null)
        {
            _pod = new Transport.Domain.Entities.Podesavanja
            {
                Broj                    = 1,
                koristiOdvojeneBrojeve  = 0,
                automatskiBrojevi       = 1,
                rucniUnosBrojFakture    = 0,
                koristiOdvojeneInoRacune = 0,
                stampaLogoAktivan       = 1,
                eFakturaAktivna         = 0,
                eOtpremnicaAktivna      = 0,
                minCifaraBroja          = 0,
                brTureAgencijski        = 1,
                sefTipServera           = "DEMO",
                eOtpremnicaTipServera   = "DEMO",
                pdvDatumObracuna        = "DATUM PROMETA",
                OpcijaString12          = "PROMET"
            };
            _noviZapis = true;
        }

        _firma = await Db.PodaciFirme.FirstOrDefaultAsync();
        if (_firma is null)
        {
            _firma = new Transport.Domain.Entities.PodaciFirme { Broj = 1 };
            _noviZapisFirma = true;
        }

        if (_firma.logoData is { Length: > 0 })
        {
            var mime = _firma.logoMimeType ?? "image/png";
            _logoPreview = $"data:{mime};base64,{Convert.ToBase64String(_firma.logoData)}";
        }

        _ucitava = false;
        StateHasChanged();
    }

    private async Task ObradiLogo(IBrowserFile file)
    {
        if (_firma is null) return;
        try
        {
            using var ms = new MemoryStream();
            await file.OpenReadStream(maxAllowedSize: 512_000).CopyToAsync(ms);
            _firma.logoData     = ms.ToArray();
            _firma.logoMimeType = file.ContentType;
            _logoPreview        = $"data:{file.ContentType};base64,{Convert.ToBase64String(_firma.logoData)}";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Greška pri učitavanju loga: {ex.Message}", Severity.Error);
        }
    }

    private void UkloniLogo()
    {
        if (_firma is null) return;
        _firma.logoData     = null;
        _firma.logoMimeType = null;
        _logoPreview        = null;
    }

    private async Task Sacuvaj()
    {
        if (_pod is null || _firma is null) return;

        // Upisati default format ako je prazan
        if (string.IsNullOrWhiteSpace(_pod.formatBrojaRacuna))             _pod.formatBrojaRacuna             = "broj-godina4";
        if (string.IsNullOrWhiteSpace(_pod.formatBrojaInoRacuna))          _pod.formatBrojaInoRacuna          = "broj-godina4";
        if (string.IsNullOrWhiteSpace(_pod.formatBrojaPredracuna))         _pod.formatBrojaPredracuna         = "broj-godina4";
        if (string.IsNullOrWhiteSpace(_pod.formatBrojaTure))               _pod.formatBrojaTure               = "broj-godina4";
        if (string.IsNullOrWhiteSpace(_pod.formatBrojaTureAgencijski))     _pod.formatBrojaTureAgencijski     = "broj-godina4";
        if (string.IsNullOrWhiteSpace(_pod.formatBrojaNaloga))             _pod.formatBrojaNaloga             = "broj-godina4";
        if (string.IsNullOrWhiteSpace(_pod.formatBrojaNalogaAgencijski))   _pod.formatBrojaNalogaAgencijski   = "broj-godina4";

        try
        {
            if (_noviZapis) { Db.Podesavanja.Add(_pod); _noviZapis = false; }
            else             { Db.Entry(_pod).State = Microsoft.EntityFrameworkCore.EntityState.Modified; }

            if (_noviZapisFirma) { Db.PodaciFirme.Add(_firma); _noviZapisFirma = false; }
            else                  { Db.Entry(_firma).State = Microsoft.EntityFrameworkCore.EntityState.Modified; }

            await Db.SaveChangesAsync();
            Snackbar.Add("Podešavanja sačuvana!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Greška pri čuvanju: {ex.Message}", Severity.Error);
        }
    }

    private string PrevBroj(int? trenutni, string? format)
        => BrojDokumentaService.Preview(trenutni ?? 0, format, _pod?.minCifaraBroja ?? 0);
}
